{% render 'custom-color-scope', section: section %}
<section class="policy-content" style="--content-pt:{{ section.settings.top_spacing }}px;--content-pb:{{ section.settings.bottom_spacing }}px"><div class="page-width content-width--{{ section.settings.content_width }}"><h1>{{ section.settings.heading | default: page.title | escape }}</h1>{% if section.settings.intro != blank %}<div class="rte">{{ section.settings.intro }}</div>{% endif %}{% if page.content != blank %}<div class="rte policy-content__body">{{ page.content }}</div>{% elsif section.settings.content != blank %}<div class="rte policy-content__body">{{ section.settings.content }}</div>{% else %}<p class="content-empty">Add policy or informational content in this page or section.</p>{% endif %}</div></section>
{% schema %}
{
  "name": "Policy content",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introductory text"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Fallback content"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "standard",
          "label": "Standard"
        }
      ]
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top spacing",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_background_secondary",
      "label": "Secondary background",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_text",
      "label": "Text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_muted_text",
      "label": "Muted text",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "custom_heading",
      "label": "Headings",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "default": "#dddddd"
    }
  ],
  "presets": [
    {
      "name": "Policy content"
    }
  ]
}
{% endschema %}
