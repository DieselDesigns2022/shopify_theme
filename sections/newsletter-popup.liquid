      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_input_border",
      "label": "Input border",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_focus",
      "label": "Focus color",
      "placeholder": "Inherited from theme style"
    }
  ]
}
{% endschema %}
