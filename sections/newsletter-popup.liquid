{% assign has_cta = false %}
{% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
  {% assign has_cta = true %}
{% endif %}
{% assign has_content = false %}
{% if section.settings.heading != blank or section.settings.text != blank or section.settings.image != blank or section.settings.newsletter or has_cta %}
  {% assign has_content = true %}
{% endif %}
{% assign is_homepage = false %}
{% if request.page_type == 'index' %}
  {% assign is_homepage = true %}
{% endif %}
{% if section.settings.enabled and has_content %}
  {% if section.settings.newsletter %}
    {% capture newsletter_form %}
      {% form 'customer', id: 'NewsletterPopupForm-' | append: section.id %}
        {% if form.posted_successfully? %}
          {% assign newsletter_success = true %}
        {% endif %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label for="PopupEmail-{{ section.id }}">Email address</label>
        <input id="PopupEmail-{{ section.id }}" type="email" name="contact[email]" value="{{ form.email | escape }}" autocomplete="email" required>
        <button class="button" type="submit">Subscribe</button>
        {% if form.posted_successfully? %}<p role="status">Thanks for subscribing.</p>{% endif %}
        {% if form.errors %}<div role="alert">{{ form.errors | default_errors }}</div>{% endif %}
      {% endform %}
    {% endcapture %}
  {% endif %}
  <section
    id="NewsletterPopup-{{ section.id }}"
    class="promotion-dialog"
    data-promotion-popup
    data-design-mode="{{ request.design_mode }}"
    data-delay="{{ section.settings.delay }}"
    data-frequency="{{ section.settings.frequency }}"
    data-days="{{ section.settings.dismiss_days }}"
    data-home-only="{{ section.settings.homepage_only }}"
    data-disable-mobile="{{ section.settings.disable_mobile }}"
    data-is-homepage="{{ is_homepage }}"
    {% if newsletter_success %}data-form-success="true"{% endif %}
    hidden
  >
    {% if section.settings.overlay %}<div class="promotion-dialog__overlay" data-dialog-overlay></div>{% endif %}
    <div class="promotion-dialog__content promotion-dialog__content--image-{{ section.settings.image_position }}" role="dialog" aria-modal="true" aria-labelledby="NewsletterPopupTitle-{{ section.id }}" tabindex="-1">
      <button class="promotion-dialog__close" type="button" data-dialog-close aria-label="{{ section.settings.close_label | default: 'Close popup' | escape }}">×</button>
      {% if section.settings.image != blank %}
        {% assign popup_image_alt = section.settings.image.alt | default: '' %}
        {% assign image_height = 800 | divided_by: section.settings.image.aspect_ratio | round %}
        {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 600, 800', width: 800, height: image_height, alt: popup_image_alt }}
      {% endif %}
      <div class="promotion-dialog__body">
        <h2 id="NewsletterPopupTitle-{{ section.id }}">{{ section.settings.heading | default: 'Stay connected' | escape }}</h2>
        {% if section.settings.text != blank %}<div>{{ section.settings.text }}</div>{% endif %}
        {% if section.settings.newsletter %}{{ newsletter_form }}{% endif %}
        {% if has_cta %}<p class="promotion-dialog__cta"><a class="button button--secondary" href="{{ section.settings.cta_link | escape }}"{% if section.settings.cta_new_window %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ section.settings.cta_label | escape }}</a></p>{% endif %}
      </div>
    </div>
  </section>
{% endif %}
{% schema %}{"name":"Newsletter popup","settings":[{"type":"checkbox","id":"enabled","label":"Enable popup","default":false},{"type":"text","id":"heading","label":"Heading","default":"Stay connected"},{"type":"richtext","id":"text","label":"Text","default":"<p>Subscribe for updates and offers.</p>"},{"type":"image_picker","id":"image","label":"Image"},{"type":"select","id":"image_position","label":"Image position","default":"top","options":[{"value":"top","label":"Top"},{"value":"left","label":"Left"},{"value":"right","label":"Right"}]},{"type":"checkbox","id":"newsletter","label":"Show newsletter form","default":true},{"type":"text","id":"cta_label","label":"CTA label"},{"type":"url","id":"cta_link","label":"CTA link"},{"type":"checkbox","id":"cta_new_window","label":"Open CTA in new window","default":false},{"type":"range","id":"delay","label":"Delay","min":0,"max":30,"step":1,"unit":"s","default":5},{"type":"select","id":"frequency","label":"Frequency","default":"session","options":[{"value":"visit","label":"Every visit"},{"value":"session","label":"Once per session"},{"value":"days","label":"Dismiss for days"}]},{"type":"range","id":"dismiss_days","label":"Dismissal days","min":1,"max":90,"step":1,"default":14},{"type":"checkbox","id":"homepage_only","label":"Show on homepage only","default":false},{"type":"checkbox","id":"disable_mobile","label":"Disable popup on mobile","default":false},{"type":"checkbox","id":"overlay","label":"Enable overlay","default":true},{"type":"text","id":"close_label","label":"Close button label","default":"Close popup"}]}{% endschema %}
