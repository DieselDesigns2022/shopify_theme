{% render 'custom-color-scope', section: section %}
{% paginate collection.products by section.settings.products_per_page %}
{% assign has_active_filters = false %}
{% for filter in collection.filters %}
  {% if filter.active_values.size > 0 or filter.min_value.value or filter.max_value.value %}{% assign has_active_filters = true %}{% endif %}
{% endfor %}
<section class="browse-section collection-page" data-browse-section style="--browse-pt:{{ section.settings.top_spacing }}px;--browse-pb:{{ section.settings.bottom_spacing }}px">
 <div class="content-width--{{ section.settings.content_width }}">
  <header class="collection-header">
   {% if section.settings.show_collection_image and collection.image != blank %}{% assign collection_image_alt = collection.image.alt | default: collection.title %}{{ collection.image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '600, 900, 1200, 1400', alt: collection_image_alt, class: 'collection-header__image' }}{% endif %}
   {% if section.settings.show_collection_description and collection.description != blank and section.settings.description_position == 'above' %}<div class="collection-header__description collection-header__description--above">{{ collection.description }}</div>{% endif %}
   <h1>{{ collection.title | escape }}</h1>
   {% if section.settings.show_collection_description and collection.description != blank and section.settings.description_position == 'below' %}<div class="collection-header__description collection-header__description--below">{{ collection.description }}</div>{% endif %}
   <p class="browse-count">{{ collection.products_count }} products</p>
  </header>
  {% if section.settings.enable_filtering or section.settings.enable_sorting %}<div class="browse-toolbar">
   {% if section.settings.enable_filtering and collection.filters.size > 0 %}<button class="browse-mobile-filter button button--secondary" type="button" data-filter-open aria-expanded="false" aria-controls="Filters-{{ section.id }}">{% render 'icon-filter' %} Filters</button>{% endif %}
   {% if section.settings.enable_sorting %}<form action="{{ collection.url }}" class="browse-sort"><label for="Sort-{{ section.id }}">Sort by</label><select id="Sort-{{ section.id }}" name="sort_by" data-sort-select>{% assign sort_by = collection.sort_by | default: collection.default_sort_by %}{% for option in collection.sort_options %}<option value="{{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>{{ option.name | escape }}</option>{% endfor %}</select>{% for filter in collection.filters %}{% for value in filter.active_values %}<input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">{% endfor %}{% if filter.min_value.value %}<input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}">{% endif %}{% if filter.max_value.value %}<input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}">{% endif %}{% endfor %}<button type="submit">Sort</button></form>{% endif %}
  </div>{% endif %}
  {% if section.settings.enable_filtering and collection.filters.size > 0 %}<aside id="Filters-{{ section.id }}" class="browse-filters browse-filters--{{ section.settings.desktop_filter_layout }}" data-filter-panel aria-label="Collection filters"><div class="browse-filters__head"><h2>Filter products</h2><button type="button" data-filter-close>Close filters</button></div><form action="{{ collection.url }}" method="get" class="facets">{% if collection.sort_by %}<input type="hidden" name="sort_by" value="{{ collection.sort_by }}">{% endif %}{% render 'facets', filters: collection.filters, section: section %}<button class="button" type="submit">Apply filters</button></form></aside>{% endif %}
  {% if has_active_filters %}<div class="active-filters" aria-label="Active filters">{% for filter in collection.filters %}{% for value in filter.active_values %}<a href="{{ value.url_to_remove }}" aria-label="Remove {{ value.label | escape }} filter">{{ value.label | escape }} ×</a>{% endfor %}{% if filter.min_value.value or filter.max_value.value %}<a href="{{ filter.url_to_remove }}" aria-label="Remove {{ filter.label | escape }} filter">Remove {{ filter.label | escape }} ×</a>{% endif %}{% endfor %}<a href="{{ collection.url }}">Clear all</a></div>{% endif %}
  {% if collection.products_count > 0 %}<div class="browse-layout{% if section.settings.enable_filtering and section.settings.desktop_filter_layout == 'sidebar' %} browse-layout--sidebar{% endif %}"><div class="product-grid" style="--desktop-columns:{{ section.settings.desktop_columns }};--mobile-columns:{{ section.settings.mobile_columns }}">{% for product in collection.products %}{% render 'product-card', product: product, show_vendor: section.settings.show_vendor, show_product_type: section.settings.show_product_type, show_description: section.settings.show_description, show_second_image: section.settings.show_second_image, show_sale_badge: section.settings.show_sale_badge, show_sold_out_badge: section.settings.show_sold_out_badge, image_ratio: section.settings.image_ratio, image_fit: section.settings.image_fit, text_alignment: section.settings.text_alignment, enable_quick_add: section.settings.enable_quick_add %}{% endfor %}</div></div>{% else %}<div class="browse-empty"><h2>No products found</h2><p>This collection does not currently contain any products.</p></div>{% endif %}
  {% render 'pagination', paginate: paginate %}
 </div>
</section>{% endpaginate %}
{% schema %}
{
  "name": "Collection product grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 12
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile columns",
      "default": "2",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "default": "wide",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
