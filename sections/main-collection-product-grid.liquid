        {
          "value": "below",
          "label": "Below title"
        },
        {
          "value": "above",
          "label": "Above title"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sorting",
      "default": true
    },
    {
