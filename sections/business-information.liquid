{% render 'custom-color-scope', section: section %}
{% liquid
  assign phone = section.settings.phone | strip
  assign email = section.settings.email | strip
  assign phone_href = phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' | remove: '.'
  assign has_button = false
  if section.settings.button_label != blank and section.settings.button_link != blank
    assign has_button = true
  endif
  assign has_details = false
  if section.settings.hours != blank or phone != blank or email != blank or section.settings.address != blank
    assign has_details = true
  endif
  assign has_content = false
  if section.settings.image != blank or section.settings.heading != blank or section.settings.intro != blank or has_details or has_button
    assign has_content = true
  endif
%}
{% if has_content %}
  <section class="business-information business-information--image-{{ section.settings.image_position }} business-information--desktop-{{ section.settings.desktop_alignment }} business-information--mobile-{{ section.settings.mobile_alignment }}{% if section.settings.image == blank %} business-information--text-only{% endif %}" style="--business-pt:{{ section.settings.padding_top }}px;--business-pb:{{ section.settings.padding_bottom }}px;--business-mobile-pt:{{ section.settings.mobile_padding_top }}px;--business-mobile-pb:{{ section.settings.mobile_padding_bottom }}px;--business-image-fit:{{ section.settings.image_fit }};">
    <div class="content-width--{{ section.settings.content_width }} business-information__grid">
      {% if section.settings.image != blank %}
        <div class="business-information__media">
          {{ section.settings.image | image_url: width: 1800 | image_tag: widths: '375, 550, 750, 1000, 1400, 1800', sizes: '(min-width: 750px) 50vw, 100vw', loading: 'lazy', width: section.settings.image.width, height: section.settings.image.height, alt: section.settings.image.alt }}
        </div>
      {% endif %}
      <div class="business-information__content">
        {% if section.settings.heading != blank %}<h2>{{ section.settings.heading | escape }}</h2>{% endif %}
        {% if section.settings.intro != blank %}<div class="business-information__intro rte">{{ section.settings.intro }}</div>{% endif %}
        {% if has_details %}
          <dl class="business-information__details">
            {% if section.settings.hours != blank %}<div class="business-information__detail">{% if section.settings.hours_label != blank %}<dt>{{ section.settings.hours_label | escape }}</dt>{% endif %}<dd class="rte">{{ section.settings.hours }}</dd></div>{% endif %}
            {% if phone != blank %}<div class="business-information__detail">{% if section.settings.phone_label != blank %}<dt>{{ section.settings.phone_label | escape }}</dt>{% endif %}<dd><a href="tel:{{ phone_href | escape }}">{{ phone | escape }}</a></dd></div>{% endif %}
            {% if email != blank %}<div class="business-information__detail">{% if section.settings.email_label != blank %}<dt>{{ section.settings.email_label | escape }}</dt>{% endif %}<dd><a href="mailto:{{ email | escape }}">{{ email | escape }}</a></dd></div>{% endif %}
            {% if section.settings.address != blank %}<div class="business-information__detail">{% if section.settings.address_label != blank %}<dt>{{ section.settings.address_label | escape }}</dt>{% endif %}<dd><address>{% if section.settings.address_link != blank %}<a href="{{ section.settings.address_link | escape }}">{{ section.settings.address | escape | newline_to_br }}</a>{% else %}{{ section.settings.address | escape | newline_to_br }}{% endif %}</address></dd></div>{% endif %}
          </dl>
        {% endif %}
        {% if has_button %}<a class="button business-information__button" href="{{ section.settings.button_link | escape }}">{{ section.settings.button_label | escape }}</a>{% endif %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Business information",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_position", "label": "Image position", "default": "left", "options": [{ "value": "left", "label": "Left" }, { "value": "right", "label": "Right" }] },
    { "type": "select", "id": "image_fit", "label": "Image fit", "default": "cover", "options": [{ "value": "cover", "label": "Cover" }, { "value": "contain", "label": "Contain" }] },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Visit or get in touch" },
    { "type": "richtext", "id": "intro", "label": "Introduction", "default": "<p>We’re here to help with product questions, orders, and recommendations. Reach out or stop by during our business hours.</p>" },
    { "type": "header", "content": "Business details" },
    { "type": "text", "id": "hours_label", "label": "Business hours label", "default": "Business hours" },
    { "type": "richtext", "id": "hours", "label": "Business hours", "default": "<p>Monday–Friday, 9:00 AM–5:00 PM</p>" },
    { "type": "text", "id": "phone_label", "label": "Phone label", "default": "Phone" },
    { "type": "text", "id": "phone", "label": "Phone number" },
    { "type": "text", "id": "email_label", "label": "Email label", "default": "Email" },
    { "type": "text", "id": "email", "label": "Email address" },
    { "type": "text", "id": "address_label", "label": "Address label", "default": "Address" },
    { "type": "textarea", "id": "address", "label": "Physical address" },
    { "type": "url", "id": "address_link", "label": "Address link" },
    { "type": "text", "id": "button_label", "label": "Contact button label", "default": "Contact us" },
    { "type": "url", "id": "button_link", "label": "Contact button link" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "content_width", "label": "Content width", "default": "wide", "options": [{ "value": "narrow", "label": "Narrow" }, { "value": "standard", "label": "Standard" }, { "value": "wide", "label": "Wide" }] },
    { "type": "select", "id": "desktop_alignment", "label": "Desktop alignment", "default": "left", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" }] },
    { "type": "select", "id": "mobile_alignment", "label": "Mobile alignment", "default": "left", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" }] },
    { "type": "range", "id": "padding_top", "label": "Desktop top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Desktop bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "mobile_padding_top", "label": "Mobile top spacing", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Mobile bottom spacing", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 40 },
    { "type": "header", "content": "Custom colors" },
    { "type": "color", "id": "custom_background", "label": "Background", "placeholder": "Inherited from theme style" },
    { "type": "color", "id": "custom_background_secondary", "label": "Secondary background", "placeholder": "Inherited from theme style" },
    { "type": "color", "id": "custom_text", "label": "Text", "placeholder": "Inherited from theme style" },
    { "type": "color", "id": "custom_muted_text", "label": "Muted text", "placeholder": "Inherited from theme style" },
    { "type": "color", "id": "custom_heading", "label": "Headings", "placeholder": "Inherited from theme style" },
    { "type": "color", "id": "custom_link", "label": "Links", "placeholder": "Inherited from theme style" },
    { "type": "color", "id": "custom_link_hover", "label": "Link hover", "placeholder": "Inherited from theme style" },
    { "type": "color", "id": "custom_border", "label": "Borders and dividers", "placeholder": "Inherited from theme style" },
    { "type": "header", "content": "Primary button" },
    { "type": "color", "id": "custom_primary_button_background", "label": "Background", "placeholder": "Inherited from theme style" },
    { "type": "color", "id": "custom_primary_button_text", "label": "Text", "placeholder": "Inherited from theme style" },
    { "type": "color", "id": "custom_primary_button_hover_background", "label": "Hover background", "placeholder": "Inherited from theme style" },
    { "type": "color", "id": "custom_primary_button_hover_text", "label": "Hover text", "placeholder": "Inherited from theme style" }
  ],
  "presets": [{ "name": "Business information" }]
}
{% endschema %}
