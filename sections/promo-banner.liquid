{% assign fallback=section.settings.image | default:section.settings.mobile_image %}{% if section.settings.width == 'page' %}{% assign banner_sizes = 'min(100vw, 1400px)' %}{% else %}{% assign banner_sizes = '100vw' %}{% endif %}<section class="home-section{% if section.settings.width == 'page' %} page-width{% endif %}"><div class="promo-banner" style="color:{{ section.settings.text_color }};--promo-fallback:{{ section.settings.fallback_background }};--promo-height:{{ section.settings.height }}px;--promo-mobile-height:{{ section.settings.mobile_height }}px;--promo-overlay:{{ section.settings.overlay }};--section-text:{{ section.settings.text_color }};--promo-overlay-opacity:{{ section.settings.opacity | divided_by:100.0 }}">{% if fallback != blank %}<picture class="promo-banner__media">{% if section.settings.mobile_image != blank %}<source media="(max-width:749px)" srcset="{{ section.settings.mobile_image | image_url:width:375 }} 375w, {{ section.settings.mobile_image | image_url:width:750 }} 750w, {{ section.settings.mobile_image | image_url:width:900 }} 900w">{% endif %}{{ fallback | image_url:width:2000 | image_tag: widths:'750,1200,2000', loading:'lazy', sizes:banner_sizes }}</picture>{% endif %}<span class="promo-banner__overlay" aria-hidden="true"></span><div class="promo-banner__content promo-banner__content--{{ section.settings.alignment }}" style="--promo-position:{{ section.settings.position }}">{% if section.settings.heading != blank %}<h2>{{ section.settings.heading | escape }}</h2>{% endif %}{% if section.settings.text != blank %}<div>{{ section.settings.text }}</div>{% endif %}<div class="button-group">{% if section.settings.button_label != blank and section.settings.button_link != blank %}<a class="button" href="{{ section.settings.button_link }}">{{ section.settings.button_label | escape }}</a>{% endif %}{% if section.settings.button_2_label != blank and section.settings.button_2_link != blank %}<a class="button button--text" href="{{ section.settings.button_2_link }}">{{ section.settings.button_2_label | escape }}</a>{% endif %}</div></div></div></section>
{% schema %}{"name":"Promotional banner","settings":[{"type":"image_picker","id":"image","label":"Desktop image"},{"type":"image_picker","id":"mobile_image","label":"Mobile image"},{"type":"text","id":"heading","label":"Heading","default":"A timely promotion"},{"type":"richtext","id":"text","label":"Text"},{"type":"text","id":"button_label","label":"Button label"},{"type":"url","id":"button_link","label":"Button link"},{"type":"text","id":"button_2_label","label":"Second button label"},{"type":"url","id":"button_2_link","label":"Second button link"},{"type":"select","id":"width","label":"Width","default":"full","options":[{"value":"full","label":"Full width"},{"value":"page","label":"Page width"}]},{"type":"select","id":"position","label":"Content position","default":"center","options":[{"value":"start","label":"Top"},{"value":"center","label":"Center"},{"value":"end","label":"Bottom"}]},{"type":"select","id":"alignment","label":"Alignment","default":"center","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}]},{"type":"color","id":"text_color","label":"Text color","default":"#ffffff"},{"type":"color","id":"fallback_background","label":"Fallback background","default":"#555555"},{"type":"color","id":"overlay","label":"Overlay","default":"#000000"},{"type":"range","id":"opacity","label":"Overlay opacity","min":0,"max":80,"step":5,"unit":"%","default":25},{"type":"range","id":"height","label":"Desktop height","min":200,"max":700,"step":20,"unit":"px","default":420},{"type":"range","id":"mobile_height","label":"Mobile height","min":200,"max":600,"step":20,"unit":"px","default":360}],"presets":[{"name":"Promotional banner"}]}{% endschema %}
