{% render 'custom-color-scope', section: section %}
<section class="home-section text-{{ section.settings.alignment }}" data-countdown data-target="{{ section.settings.target | escape }}" style="--section-bg:{{ section.settings.background }};--section-text:{{ section.settings.text_color }}"><div class="content-width--standard">{% if section.settings.heading != blank %}<h2>{{ section.settings.heading | escape }}</h2>{% endif %}{% if section.settings.text != blank %}<div>{{ section.settings.text }}</div>{% endif %}<p class="visually-hidden">Deadline: <time datetime="{{ section.settings.target | escape }}">{{ section.settings.target | date: '%B %-d, %Y at %-I:%M %p' }}</time></p><div class="countdown" data-countdown-units hidden aria-hidden="true">{% assign countdown_units = 'days,hours,minutes,seconds' | split: ',' %}{% for item in countdown_units %}<div class="countdown__unit card"><span class="countdown__number" data-countdown-{{ item }}>0</span><span>{{ item | capitalize }}</span></div>{% endfor %}</div><p class="countdown__status" data-countdown-complete role="status" hidden>{{ section.settings.completed | default: 'This offer has ended.' | escape }}</p><p data-countdown-invalid hidden>Set a valid ISO 8601 target date in the Theme Editor.</p><noscript><p>{{ section.settings.target | escape }}{% if section.settings.completed != blank %} — {{ section.settings.completed | default: 'This offer has ended.' | escape }}{% endif %}</p></noscript>{% if section.settings.button_label != blank and section.settings.button_link != blank %}<a class="button" href="{{ section.settings.button_link }}">{{ section.settings.button_label | escape }}</a>{% endif %}</div></section>
{% schema %}
{
  "name": "Countdown",
  "settings": [
    {
      "type": "text",
      "id": "target",
      "label": "Target date and time (ISO 8601)",
      "default": "2027-01-01T00:00:00Z"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Offer ends soon"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "completed",
      "label": "Completed message",
      "default": "This offer has ended."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_background_secondary",
      "label": "Secondary background",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_text",
      "label": "Text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_heading",
      "label": "Headings",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "default": "#dddddd"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "color",
      "id": "custom_primary_button_background",
      "label": "Primary button background",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_primary_button_text",
      "label": "Primary button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_background",
      "label": "Primary button hover background",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_text",
      "label": "Primary button hover text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Countdown"
    }
  ]
}
{% endschema %}
