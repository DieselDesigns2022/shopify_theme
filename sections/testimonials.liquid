<section class="home-section testimonials"><div class="content-width--wide text-{{ section.settings.alignment }}">{% if section.settings.heading != blank %}<h2>{{ section.settings.heading | escape }}</h2>{% endif %}<div class="testimonials__grid" style="--desktop-columns:{{ section.settings.columns }};--mobile-columns:1">{% for block in section.blocks %}<figure {{ block.shopify_attributes }} class="card feature-list__item">{% if block.settings.rating > 0 %}<p aria-label="{{ block.settings.rating }} out of 5 stars"><span aria-hidden="true">{% for i in (1..block.settings.rating) %}★{% endfor %}</span></p>{% endif %}<blockquote>{{ block.settings.quote }}</blockquote><figcaption>{% if block.settings.image != blank %}{{ block.settings.image | image_url:width:100 | image_tag: loading:'lazy', alt:'' }}{% endif %}<strong>{{ block.settings.name | escape }}</strong>{% if block.settings.detail != blank %}<span>{{ block.settings.detail | escape }}</span>{% endif %}</figcaption></figure>{% endfor %}</div></div></section>
{% schema %}{"name":"Testimonials","max_blocks":8,"settings":[{"type":"text","id":"heading","label":"Heading","default":"Loved by customers"},{"type":"range","id":"columns","label":"Desktop columns","min":1,"max":4,"step":1,"default":3},{"type":"select","id":"alignment","label":"Alignment","default":"center","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}]}],"blocks":[{"type":"testimonial","name":"Testimonial","settings":[{"type":"richtext","id":"quote","label":"Quote","default":"<p>Share a customer review here.</p>"},{"type":"text","id":"name","label":"Customer name","default":"Customer name"},{"type":"text","id":"detail","label":"Customer detail"},{"type":"image_picker","id":"image","label":"Customer image"},{"type":"range","id":"rating","label":"Rating","min":0,"max":5,"step":1,"default":5}]}],"presets":[{"name":"Testimonials","blocks":[{"type":"testimonial"},{"type":"testimonial"},{"type":"testimonial"}]}]}{% endschema %}
