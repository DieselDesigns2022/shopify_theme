{% render 'custom-color-scope', section: section %}
{% assign found = 0 %}
{% capture cards %}
  {% for candidate in blog.articles limit: 12 %}
    {% if candidate.id != article.id and found < section.settings.maximum_articles %}{% assign matched = false %}{% for tag in article.tags limit: 8 %}{% if candidate.tags contains tag %}{% assign matched = true %}{% endif %}{% endfor %}{% if matched %}{% render 'article-card', article: candidate, show_image: section.settings.show_images, show_meta: section.settings.show_metadata, show_author: section.settings.show_author, show_excerpt: section.settings.show_excerpt, show_tags: false %}{% assign found = found | plus: 1 %}{% endif %}{% endif %}
  {% endfor %}
  {% if found < section.settings.maximum_articles %}{% for candidate in blog.articles limit: 12 %}{% if candidate.id != article.id and found < section.settings.maximum_articles %}{% assign matched = false %}{% for tag in article.tags limit: 8 %}{% if candidate.tags contains tag %}{% assign matched = true %}{% endif %}{% endfor %}{% unless matched %}{% render 'article-card', article: candidate, show_image: section.settings.show_images, show_meta: section.settings.show_metadata, show_author: section.settings.show_author, show_excerpt: section.settings.show_excerpt, show_tags: false %}{% assign found = found | plus: 1 %}{% endunless %}{% endif %}{% endfor %}{% endif %}
{% endcapture %}
{% if found > 0 %}<section class="related-articles"><div class="page-width content-width--{{ section.settings.content_width }}">{% if section.settings.heading != blank %}<h2>{{ section.settings.heading | escape }}</h2>{% endif %}<div class="article-grid article-grid--{{ section.settings.columns }}">{{ cards }}</div></div></section>{% endif %}
{% schema %}
{
  "name": "Related articles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Related articles"
    },
    {
      "type": "range",
      "id": "maximum_articles",
      "label": "Maximum articles",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "default": "3",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "default": "wide",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_images",
      "label": "Show images",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_metadata",
      "label": "Show metadata",
      "default": true
    },
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_background_secondary",
      "label": "Secondary background",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_text",
      "label": "Text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_muted_text",
      "label": "Muted text",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "custom_heading",
      "label": "Headings",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "default": "#dddddd"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "color",
      "id": "custom_card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_card_text",
      "label": "Card text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_card_heading",
      "label": "Card heading",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "custom_card_border",
      "label": "Card border",
      "default": "#dddddd"
    },
    {
      "type": "color",
      "id": "custom_card_link",
      "label": "Card link",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_card_link_hover",
      "label": "Card link hover",
      "default": "#555555"
    }
  ]
}
{% endschema %}
