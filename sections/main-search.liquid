{% render 'custom-color-scope', section: section %}
{% paginate search.results by section.settings.results_per_page %}
{% assign has_active_filters = false %}
{% for filter in search.filters %}
  {% if filter.active_values.size > 0 or filter.min_value.value or filter.max_value.value %}{% assign has_active_filters = true %}{% endif %}
{% endfor %}
<section class="browse-section search-page" data-browse-section style="--browse-pt:{{ section.settings.top_spacing }}px;--browse-pb:{{ section.settings.bottom_spacing }}px">
  <div class="content-width--{{ section.settings.content_width }}">
    <header class="search-header">
      <h1>Search</h1>
      <form action="{{ routes.search_url }}" method="get" role="search" class="search-form"><label for="Search-{{ section.id }}">Search products, articles, and pages</label><input id="Search-{{ section.id }}" type="search" name="q" value="{{ search.terms | escape }}"><input type="hidden" name="options[prefix]" value="last"><button class="button" type="submit">Search</button></form>
      {% if search.performed %}<p class="browse-count">{{ search.results_count }} results for “{{ search.terms | escape }}”</p>{% endif %}
    </header>
    {% if search.performed == false %}
      <div class="browse-empty"><h2>Start your search</h2><p>Enter a term above to find products, articles, and pages.</p></div>
    {% elsif search.results_count == 0 %}
      <div class="browse-empty"><h2>No results found</h2><p>Check the spelling, try a shorter term, or <a href="{{ routes.all_products_collection_url }}">browse the catalog</a>.</p></div>
    {% else %}
      {% if search.sort_options != blank %}
        <form action="{{ routes.search_url }}" method="get" class="browse-sort"><label for="SearchSort-{{ section.id }}">Sort by</label><input type="hidden" name="q" value="{{ search.terms | escape }}"><input type="hidden" name="options[prefix]" value="last"><select id="SearchSort-{{ section.id }}" name="sort_by" data-sort-select>{% assign sort_by = search.sort_by | default: search.default_sort_by %}{% for option in search.sort_options %}<option value="{{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>{{ option.name | escape }}</option>{% endfor %}</select>{% for filter in search.filters %}{% for value in filter.active_values %}<input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">{% endfor %}{% if filter.min_value.value %}<input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}">{% endif %}{% if filter.max_value.value %}<input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}">{% endif %}{% endfor %}<button type="submit">Sort</button></form>
      {% endif %}
      {% if search.filters.size > 0 %}
        <button class="browse-mobile-filter button button--secondary" type="button" data-filter-open aria-expanded="false" aria-controls="Filters-{{ section.id }}">{% render 'icon-filter' %} Filters</button>
        <aside id="Filters-{{ section.id }}" class="browse-filters" data-filter-panel aria-label="Search filters"><div class="browse-filters__head"><h2>Filter results</h2><button type="button" data-filter-close>Close filters</button></div><form action="{{ routes.search_url }}" method="get" class="facets"><input type="hidden" name="q" value="{{ search.terms | escape }}"><input type="hidden" name="options[prefix]" value="last">{% if search.sort_by %}<input type="hidden" name="sort_by" value="{{ search.sort_by }}">{% endif %}{% render 'facets', filters: search.filters, section: section %}<button class="button" type="submit">Apply filters</button></form></aside>
      {% endif %}
      {% if has_active_filters %}<div class="active-filters" aria-label="Active filters">{% for filter in search.filters %}{% for value in filter.active_values %}<a href="{{ value.url_to_remove }}" aria-label="Remove {{ value.label | escape }} filter">{{ value.label | escape }} ×</a>{% endfor %}{% if filter.min_value.value or filter.max_value.value %}<a href="{{ filter.url_to_remove }}" aria-label="Remove {{ filter.label | escape }} filter">Remove {{ filter.label | escape }} ×</a>{% endif %}{% endfor %}<a href="{{ routes.search_url }}?q={{ search.terms | url_encode }}&amp;options%5Bprefix%5D=last">Clear all</a></div>{% endif %}
      <div class="search-results product-grid" style="--desktop-columns:{{ section.settings.desktop_columns }};--mobile-columns:{{ section.settings.mobile_columns }}">{% for item in search.results %}{% if item.object_type == 'product' %}{% render 'product-card', product: item, show_vendor: section.settings.show_vendor, show_product_type: section.settings.show_product_type, show_description: section.settings.show_description, show_second_image: section.settings.show_second_image, show_sale_badge: section.settings.show_sale_badge, show_sold_out_badge: section.settings.show_sold_out_badge, image_ratio: section.settings.image_ratio, image_fit: section.settings.image_fit, text_alignment: section.settings.text_alignment, enable_quick_add: section.settings.enable_quick_add %}{% else %}<article class="search-result card"><p class="search-result__type">{% if section.settings.show_result_type_labels %}{{ item.object_type | escape }}{% endif %}</p><h2><a href="{{ item.url }}">{{ item.title | escape }}</a></h2>{% if item.content != blank %}<p>{{ item.content | strip_html | truncate: 160 | escape }}</p>{% endif %}</article>{% endif %}{% endfor %}</div>
      {% render 'pagination', paginate: paginate %}
    {% endif %}
  </div>
</section>
{% endpaginate %}
{% schema %}
{
  "name": "Search",
  "settings": [
    {
      "type": "range",
      "id": "results_per_page",
      "label": "Results per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 12
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "default": "wide",
