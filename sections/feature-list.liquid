<section class="home-section feature-list feature-list--{{ section.settings.layout }}">
  <div class="content-width--wide text-{{ section.settings.alignment }}">
    {% if section.settings.heading != blank %}<h2>{{ section.settings.heading | escape }}</h2>{% endif %}
    <div class="feature-list__grid" style="--desktop-columns: {{ section.settings.columns }}; --mobile-columns: {{ section.settings.mobile_columns }}; --icon-size: {{ section.settings.icon_size }}px;">
      {% for block in section.blocks %}
        <article class="feature-list__item{% if section.settings.layout == 'card' %} card{% endif %}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}<img class="feature-list__icon" src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="200" height="200">{% endif %}
          {% if block.settings.heading != blank %}<h3>{{ block.settings.heading | escape }}</h3>{% endif %}
          {% if block.settings.text != blank %}<div>{{ block.settings.text }}</div>{% endif %}
          {% if block.settings.link_label != blank and block.settings.link != blank %}<a href="{{ block.settings.link }}">{{ block.settings.link_label | escape }}</a>{% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{"name":"Feature list","max_blocks":8,"settings":[{"type":"text","id":"heading","label":"Heading","default":"Why choose us"},{"type":"range","id":"columns","label":"Desktop columns","min":2,"max":4,"step":1,"default":3},{"type":"select","id":"mobile_columns","label":"Mobile columns","default":"1","options":[{"value":"1","label":"1 column"},{"value":"2","label":"2 columns"}]},{"type":"range","id":"icon_size","label":"Icon size","min":24,"max":96,"step":4,"unit":"px","default":48},{"type":"select","id":"layout","label":"Layout","default":"card","options":[{"value":"card","label":"Card"},{"value":"plain","label":"Plain"}]},{"type":"select","id":"alignment","label":"Alignment","default":"center","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}]}],"blocks":[{"type":"feature","name":"Feature","settings":[{"type":"image_picker","id":"image","label":"Icon image"},{"type":"text","id":"heading","label":"Heading","default":"Thoughtful details"},{"type":"richtext","id":"text","label":"Text"},{"type":"text","id":"link_label","label":"Link label"},{"type":"url","id":"link","label":"Link"}]}],"presets":[{"name":"Feature list","blocks":[{"type":"feature"},{"type":"feature"},{"type":"feature"}]}]}
{% endschema %}
