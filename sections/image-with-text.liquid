{% render 'custom-color-scope', section: section %}
{% assign fallback = section.settings.image | default: section.settings.mobile_image %}
<section class="home-section image-with-text image-with-text--{{ section.settings.image_position }}" style="--section-bg: {{ section.settings.background }}; --section-text: {{ section.settings.text_color }}; --image-column: {{ section.settings.image_width }}fr; --image-fit: {{ section.settings.fit }};">
  <div class="content-width--{{ section.settings.width }} image-with-text__grid">
    <div class="image-with-text__image image-fit">
      {% if fallback != blank %}
        <picture>
          {% if section.settings.mobile_image != blank %}<source media="(max-width: 749px)" srcset="{{ section.settings.mobile_image | image_url: width: 750 }}">{% endif %}
          <img src="{{ fallback | image_url: width: 1400 }}" alt="{{ fallback.alt | escape }}" loading="lazy" width="{{ fallback.width }}" height="{{ fallback.height }}">
        </picture>
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
    <div class="image-with-text__content text-{{ section.settings.alignment }}">
      {% if section.settings.eyebrow != blank %}<p>{{ section.settings.eyebrow | escape }}</p>{% endif %}
      {% if section.settings.heading != blank %}<h2>{{ section.settings.heading | escape }}</h2>{% endif %}
      {% if section.settings.text != blank %}<div>{{ section.settings.text }}</div>{% endif %}
      <div class="button-group">
        {% if section.settings.button_label != blank and section.settings.button_link != blank %}<a class="button" href="{{ section.settings.button_link }}">{{ section.settings.button_label | escape }}</a>{% endif %}
        {% if section.settings.button_2_label != blank and section.settings.button_2_link != blank %}<a class="button button--text" href="{{ section.settings.button_2_link }}">{{ section.settings.button_2_label | escape }}</a>{% endif %}
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Image with text",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tell your story"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Second button label"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Second button link"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "width",
      "label": "Content width",
      "default": "wide",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_width",
      "label": "Image width ratio",
      "default": "1",
      "options": [
        {
          "value": "1",
          "label": "Equal columns"
        },
        {
          "value": "1.5",
          "label": "Image wider"
        },
        {
          "value": "2",
          "label": "Image widest"
        }
      ]
    },
    {
      "type": "select",
      "id": "fit",
      "label": "Image fit",
      "default": "cover",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        }
      ]
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_background_secondary",
      "label": "Secondary background",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_text",
      "label": "Text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_heading",
      "label": "Headings",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "default": "#dddddd"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "color",
      "id": "custom_primary_button_background",
      "label": "Primary button background",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_primary_button_text",
      "label": "Primary button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_background",
      "label": "Primary button hover background",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_text",
      "label": "Primary button hover text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_secondary_button_background",
      "label": "Secondary button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_secondary_button_text",
      "label": "Secondary button text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_secondary_button_border",
      "label": "Secondary button border",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_secondary_button_hover_background",
      "label": "Secondary button hover background",
      "default": "#eeeeee"
    },
    {
      "type": "color",
      "id": "custom_secondary_button_hover_text",
      "label": "Secondary button hover text",
      "default": "#111111"
    }
  ],
  "presets": [
    {
      "name": "Image with text"
    }
  ]
}
{% endschema %}
