{% render 'custom-color-scope', section: section %}
{% assign current_variant = product.selected_variant | default: product.selected_or_first_available_variant %}
{% assign featured_media = current_variant.featured_media | default: product.featured_media %}
{% if featured_media == blank %}{% assign featured_media = product.media.first %}{% endif %}
{% assign product_form_id = 'ProductForm-' | append: section.id %}
{% assign section_position = section.index | default: 999 %}
{% assign has_file_upload = false %}{% for block in section.blocks %}{% if block.type == 'file_upload' %}{% assign has_file_upload = true %}{% endif %}{% endfor %}
<section class="main-product" data-product-section data-section-id="{{ section.id }}" data-product-url="{{ product.url }}" data-money-format="{{ shop.money_format | strip_html | escape }}" style="--product-pt: {{ section.settings.top_spacing }}px; --product-pb: {{ section.settings.bottom_spacing }}px;">
  <script type="application/json" data-product-variants>{{ product.variants | json }}</script>
  <div class="main-product__grid content-width--{{ section.settings.content_width }} main-product__grid--media-{{ section.settings.desktop_media_position }} main-product__grid--{{ section.settings.desktop_media_width }}">
    <div class="product-gallery{% if product.media.size > 1 %} product-gallery--has-thumbnails product-gallery--thumbs-{{ section.settings.desktop_thumbnail_position }}{% endif %}{% unless section.settings.show_mobile_thumbnails %} product-gallery--hide-mobile-thumbnails{% endunless %}" data-product-gallery{% if featured_media != blank %} data-initial-media-id="{{ featured_media.id }}"{% endif %} style="--product-image-fit: {{ section.settings.image_fit }};">
      <div class="product-gallery__stage" data-product-stage>
        {% if product.media.size > 0 %}
          {% for media in product.media %}{% assign media_loading = 'lazy' %}{% assign media_is_selected = false %}{% if media.id == featured_media.id %}{% assign media_is_selected = true %}{% if section_position <= 2 %}{% assign media_loading = 'eager' %}{% endif %}{% endif %}{% render 'product-media', media: media, media_index: forloop.index, media_loading: media_loading, media_is_selected: media_is_selected, product: product, section: section %}{% endfor %}
        {% else %}
          <div class="product-gallery__empty">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {% endif %}
      </div>
      {% if product.media.size > 1 %}
        <div class="product-gallery__controls" data-product-gallery-controls>
          <button type="button" data-product-gallery-prev aria-label="Previous media">{% render 'icon-chevron-left' %}</button>
          <button type="button" data-product-gallery-next aria-label="Next media">{% render 'icon-chevron-right' %}</button>
        </div>
        <div class="product-gallery__thumbnails" aria-label="Product media" data-product-thumbnails>
          {% for media in product.media %}<button type="button" class="product-gallery__thumbnail" data-product-thumbnail data-media-id="{{ media.id }}" aria-label="Show media {{ forloop.index }} of {{ product.media.size }}" aria-selected="{% if media.id == featured_media.id %}true{% else %}false{% endif %}">{{ media.preview_image | image_url: width: 160 | image_tag: loading: 'lazy', widths: '80, 160', width: media.preview_image.width, height: media.preview_image.height, alt: media.alt }}</button>{% endfor %}
        </div>
      {% endif %}
      {% if section.settings.enable_image_zoom %}
        <div class="product-gallery__modal" data-product-modal hidden inert role="dialog" aria-modal="true" aria-hidden="true" aria-label="Product image viewer">
          <div class="product-gallery__modal-inner">
            <button type="button" class="product-gallery__modal-close" data-product-modal-close aria-label="Close image viewer">{% render 'icon-close' %}</button>
            <img data-product-modal-image src="" alt="" width="1800" height="1800">
          </div>
        </div>
      {% endif %}
    </div>
    <div class="main-product__content">
      {% for block in section.blocks %}
          <div class="product-block product-block--{{ block.type }}" data-color-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
            {% case block.type %}
              {% when 'title' %}<h1>{{ product.title | escape }}</h1>
              {% when 'vendor' %}{% if section.settings.show_vendor and product.vendor != blank %}<p class="product-vendor">{{ product.vendor | escape }}</p>{% endif %}
              {% when 'price' %}{% render 'price', product: product, use_variant: current_variant %}
              {% when 'variant_picker' %}{% unless product.has_only_default_variant %}{% render 'product-variant-options', product: product, current_variant: current_variant, section: section, block: block %}{% endunless %}
              {% when 'personalization' %}{% render 'product-personalization', section: section, block: block, product_form_id: product_form_id %}
              {% when 'custom_product_option' %}{% render 'product-custom-option', section: section, block: block, product_form_id: product_form_id %}
              {% when 'file_upload' %}{% assign upload_id = 'FileUpload-' | append: section.id | append: '-' | append: block.id %}{% assign upload_help_id = upload_id | append: '-help' %}{% assign upload_status_id = upload_id | append: '-status' %}{% assign upload_notice_id = upload_id | append: '-notice' %}<div class="product-file-upload">{% if block.settings.heading != blank %}<h2>{{ block.settings.heading | escape }}</h2>{% endif %}{% if block.settings.instructions != blank %}<div id="{{ upload_help_id }}" class="rte">{{ block.settings.instructions }}</div>{% endif %}<label for="{{ upload_id }}">{{ block.settings.field_label | default: 'Upload a file' | escape }}{% if block.settings.required %}<span aria-hidden="true"> *</span>{% endif %}</label><input id="{{ upload_id }}" type="file" name="properties[{{ block.settings.field_label | default: 'Upload a file' | escape }}]" form="{{ product_form_id }}"{% if block.settings.required %} required{% endif %}{% if block.settings.accepted_file_types != blank %} accept="{{ block.settings.accepted_file_types | escape }}"{% endif %} aria-describedby="{% if block.settings.instructions != blank %}{{ upload_help_id }} {% endif %}{{ upload_status_id }}{% if block.settings.maximum_size_notice != blank %} {{ upload_notice_id }}{% endif %}" data-file-input><p id="{{ upload_status_id }}" class="product-file-upload__status" data-file-name aria-live="polite">No file selected.</p>{% if block.settings.maximum_size_notice != blank %}<p id="{{ upload_notice_id }}" class="product-file-upload__notice">{{ block.settings.maximum_size_notice | escape }}</p>{% endif %}</div>
              {% when 'size_chart' %}{% render 'product-size-chart', section: section, block: block %}
              {% when 'description' %}{% if product.description != blank %}<div class="product-description rte">{{ product.description }}</div>{% endif %}
              {% when 'quantity_selector' %}<div class="product-quantity"><label for="Quantity-{{ section.id }}">Quantity</label><div class="product-quantity__control"><button type="button" data-quantity-decrease aria-label="Decrease quantity">{% render 'icon-minus' %}</button><input id="Quantity-{{ section.id }}" form="{{ product_form_id }}" type="number" name="quantity" value="1" min="1" inputmode="numeric"><button type="button" data-quantity-increase aria-label="Increase quantity">{% render 'icon-plus' %}</button></div></div>
              {% when 'buy_buttons' %}<div class="product-buy-buttons">{% if has_file_upload %}{% form 'product', product, id: product_form_id, class: 'product-form', enctype: 'multipart/form-data', data-product-form: '' %}<input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id disabled><noscript><label for="Variant-{{ section.id }}">Variant</label><select id="Variant-{{ section.id }}" name="id">{% for variant in product.variants %}<option value="{{ variant.id }}"{% if variant.id == current_variant.id %} selected{% endif %}{% unless variant.available %} disabled{% endunless %}>{{ variant.title | escape }} — {{ variant.price | money }}{% unless variant.available %} — Sold out{% endunless %}</option>{% endfor %}</select></noscript><button type="submit" name="add" class="button" data-add-to-cart{% unless product.available %} disabled{% endunless %}><span data-add-to-cart-label>{% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}</span></button>{% if section.settings.show_dynamic_checkout %}<div data-dynamic-checkout{% unless current_variant.available %} hidden{% endunless %}>{{ form | payment_button }}</div>{% endif %}{% endform %}{% else %}{% form 'product', product, id: product_form_id, class: 'product-form', data-product-form: '' %}<input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id disabled><noscript><label for="Variant-{{ section.id }}">Variant</label><select id="Variant-{{ section.id }}" name="id">{% for variant in product.variants %}<option value="{{ variant.id }}"{% if variant.id == current_variant.id %} selected{% endif %}{% unless variant.available %} disabled{% endunless %}>{{ variant.title | escape }} — {{ variant.price | money }}{% unless variant.available %} — Sold out{% endunless %}</option>{% endfor %}</select></noscript><button type="submit" name="add" class="button" data-add-to-cart{% unless product.available %} disabled{% endunless %}><span data-add-to-cart-label>{% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}</span></button>{% if section.settings.show_dynamic_checkout %}<div data-dynamic-checkout{% unless current_variant.available %} hidden{% endunless %}>{{ form | payment_button }}</div>{% endif %}{% endform %}{% endif %}</div>
              {% when 'collapsible_row' %}{% if block.settings.heading != blank or block.settings.content != blank or block.settings.page.content != blank %}<details class="product-collapsible"><summary>{{ block.settings.heading | default: block.settings.page.title | escape }}</summary><div class="rte">{% if block.settings.content != blank %}{{ block.settings.content }}{% elsif block.settings.page != blank %}{{ block.settings.page.content }}{% endif %}</div></details>{% endif %}
              {% when 'text' %}{% if block.settings.text != blank %}<div class="product-text rte">{{ block.settings.text }}</div>{% endif %}
              {% when '@app' %}{% render block %}
            {% endcase %}
          </div>
      {% endfor %}
      {% if section.settings.show_tax_shipping_message %}<p class="product-tax-message">{% if cart.taxes_included %}Tax included.{% endif %} {% if shop.shipping_policy.body != blank %}{{ 'Shipping calculated at checkout.' | link_to: shop.shipping_policy.url }}{% else %}Shipping calculated at checkout.{% endif %}</p>{% endif %}
      {% if current_variant.store_availabilities.size > 0 %}<div class="product-pickup" data-store-availability-container><strong>Pickup available</strong>{% for availability in current_variant.store_availabilities limit: 1 %}<p>{{ availability.location.name | escape }}{% if availability.available %} — Available{% endif %}</p>{% endfor %}</div>{% endif %}
      <p class="product-variant-status" data-variant-status role="status" aria-live="polite"></p>
    </div>
  </div>
</section>
