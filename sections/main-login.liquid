<section class="customer-page page-width"><h1>Sign in</h1>{% form 'customer_login' %}{% if form.errors %}<div role="alert">{{ form.errors | default_errors }}</div>{% endif %}<label for="CustomerEmail-{{ section.id }}">Email</label><input id="CustomerEmail-{{ section.id }}" type="email" name="customer[email]" value="{{ form.email | escape }}" autocomplete="email" required><label for="CustomerPassword-{{ section.id }}">Password</label><input id="CustomerPassword-{{ section.id }}" type="password" name="customer[password]" autocomplete="current-password" required><button class="button">Sign in</button>{% endform %}{% if shop.checkout.guest_login %}<hr>{% form 'guest_login' %}<button class="button button--secondary">Continue as guest</button>{% endform %}{% endif %}<p><a href="#RecoverPassword-{{ section.id }}">Forgot password?</a> · <a href="{{ routes.account_register_url }}">Create account</a></p><div id="RecoverPassword-{{ section.id }}"><h2>Reset your password</h2>{% form 'recover_customer_password' %}{% if form.posted_successfully? %}<p role="status">Check your email for reset instructions.</p>{% endif %}{% if form.errors %}<div role="alert">{{ form.errors | default_errors }}</div>{% endif %}<label for="RecoverEmail-{{ section.id }}">Email</label><input id="RecoverEmail-{{ section.id }}" type="email" name="email" autocomplete="email" required><button class="button button--secondary">Send reset link</button>{% endform %}</div></section>{% schema %}{"name":"Customer login"}{% endschema %}
