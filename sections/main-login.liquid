{% render 'custom-color-scope', section: section %}
<section class="customer-page page-width"><h1>Sign in</h1>{% form 'customer_login' %}{% if form.errors %}<div role="alert">{{ form.errors | default_errors }}</div>{% endif %}<label for="CustomerEmail-{{ section.id }}">Email</label><input id="CustomerEmail-{{ section.id }}" type="email" name="customer[email]" value="{{ form.email | escape }}" autocomplete="email" required><label for="CustomerPassword-{{ section.id }}">Password</label><input id="CustomerPassword-{{ section.id }}" type="password" name="customer[password]" autocomplete="current-password" required><button class="button">Sign in</button>{% endform %}{% if shop.checkout.guest_login %}<hr>{% form 'guest_login' %}<button class="button button--secondary">Continue as guest</button>{% endform %}{% endif %}<p><a href="#RecoverPassword-{{ section.id }}">Forgot password?</a> · <a href="{{ routes.account_register_url }}">Create account</a></p><div id="RecoverPassword-{{ section.id }}"><h2>Reset your password</h2>{% form 'recover_customer_password' %}{% if form.posted_successfully? %}<p role="status">Check your email for reset instructions.</p>{% endif %}{% if form.errors %}<div role="alert">{{ form.errors | default_errors }}</div>{% endif %}<label for="RecoverEmail-{{ section.id }}">Email</label><input id="RecoverEmail-{{ section.id }}" type="email" name="email" autocomplete="email" required><button class="button button--secondary">Send reset link</button>{% endform %}</div></section>{% schema %}
{
  "name": "Customer login",
  "settings": [
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_background_secondary",
      "label": "Secondary background",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_text",
      "label": "Text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_muted_text",
      "label": "Muted text",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "custom_heading",
      "label": "Headings",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "default": "#dddddd"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "color",
      "id": "custom_primary_button_background",
      "label": "Primary button background",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_primary_button_text",
      "label": "Primary button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_background",
      "label": "Primary button hover background",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_text",
      "label": "Primary button hover text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_secondary_button_background",
      "label": "Secondary button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_secondary_button_text",
      "label": "Secondary button text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_secondary_button_border",
      "label": "Secondary button border",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_secondary_button_hover_background",
      "label": "Secondary button hover background",
      "default": "#eeeeee"
    },
    {
      "type": "color",
      "id": "custom_secondary_button_hover_text",
      "label": "Secondary button hover text",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Forms"
    },
    {
      "type": "color",
      "id": "custom_input_background",
      "label": "Input background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_input_text",
      "label": "Input text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_input_border",
      "label": "Input border",
      "default": "#777777"
    },
    {
      "type": "color",
      "id": "custom_focus",
      "label": "Focus color",
      "default": "#2463eb"
    }
  ]
}
{% endschema %}
