<section class="customer-page page-width"><h1>Create account</h1>{% form 'create_customer' %}{% if form.errors %}<div role="alert">{{ form.errors | default_errors }}</div>{% endif %}{% for item in 'first_name,last_name,email,password' | split: ',' %}<label for="Register{{ item | capitalize }}-{{ section.id }}">{{ item | replace: '_', ' ' | capitalize }}</label><input id="Register{{ item | capitalize }}-{{ section.id }}" {% if item == 'email' %}type="email" autocomplete="email"{% elsif item == 'password' %}type="password" autocomplete="new-password"{% else %}type="text" autocomplete="{{ item | replace: 'first_name', 'given-name' | replace: 'last_name', 'family-name' }}"{% endif %} name="customer[{{ item }}]"{% if item != 'password' %} value="{{ form[item] | escape }}"{% endif %} required>{% endfor %}<button class="button">Create account</button>{% endform %}<p><a href="{{ routes.account_login_url }}">Sign in instead</a></p></section>{% schema %}{"name":"Customer registration"}{% endschema %}
