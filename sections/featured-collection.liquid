{% render 'custom-color-scope', section: section %}
<section class="home-section featured-collection" style="--section-pt: {{ section.settings.padding_top }}px; --section-pb: {{ section.settings.padding_bottom }}px;">
  <div class="content-width--{{ section.settings.width }} text-{{ section.settings.alignment }}">
    <div class="featured-collection__header">
      <div class="section-heading">
        {% if section.settings.heading != blank %}<h2>{{ section.settings.heading | escape }}</h2>{% endif %}
        {% if section.settings.intro != blank %}<div class="featured-collection__intro rte">{{ section.settings.intro }}</div>{% endif %}
      </div>
      {% if section.settings.show_view_all and section.settings.collection != blank %}<a class="button button--text featured-collection__view-all" href="{{ section.settings.collection.url }}">{{ section.settings.view_all_label | escape }}</a>{% endif %}
    </div>

    {% if section.settings.collection != blank and section.settings.collection.products_count > 0 %}
      <div class="product-grid featured-collection__grid" style="--desktop-columns: {{ section.settings.desktop_columns }}; --mobile-columns: {{ section.settings.mobile_columns }};">
        {% for product in section.settings.collection.products limit: section.settings.product_limit %}
          {% render 'product-card', product: product, image_ratio: section.settings.image_ratio, image_fit: section.settings.image_fit, text_alignment: section.settings.card_alignment, show_vendor: section.settings.show_vendor, show_product_type: false, show_description: section.settings.show_description, show_second_image: section.settings.show_second_image, show_sale_badge: section.settings.show_sale_badge, show_sold_out_badge: section.settings.show_sold_out_badge, enable_quick_add: section.settings.enable_quick_add %}
        {% endfor %}
      </div>
    {% elsif request.design_mode %}
      <div class="section-editor-empty"><strong>Choose a collection</strong><span>Select a collection with products to preview this section.</span></div>
    {% endif %}
  </div>
</section>

{% schema %}
