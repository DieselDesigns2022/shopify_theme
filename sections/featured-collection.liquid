<section class="home-section featured-collection" style="--section-pt: {{ section.settings.padding_top }}px; --section-pb: {{ section.settings.padding_bottom }}px;">
  <div class="content-width--{{ section.settings.width }} text-{{ section.settings.alignment }}">
    <div class="featured-collection__header">
      <div class="section-heading">
        {% if section.settings.heading != blank %}<h2>{{ section.settings.heading | escape }}</h2>{% endif %}
        {% if section.settings.intro != blank %}<div class="featured-collection__intro rte">{{ section.settings.intro }}</div>{% endif %}
      </div>
      {% if section.settings.show_view_all and section.settings.collection != blank %}<a class="button button--text featured-collection__view-all" href="{{ section.settings.collection.url }}">{{ section.settings.view_all_label | escape }}</a>{% endif %}
    </div>

    {% if section.settings.collection != blank and section.settings.collection.products_count > 0 %}
      <div class="product-grid featured-collection__grid" style="--desktop-columns: {{ section.settings.desktop_columns }}; --mobile-columns: {{ section.settings.mobile_columns }};">
        {% for product in section.settings.collection.products limit: section.settings.product_limit %}
          {% render 'product-card', product: product, image_ratio: section.settings.image_ratio, image_fit: section.settings.image_fit, text_alignment: section.settings.card_alignment, show_vendor: section.settings.show_vendor, show_product_type: false, show_description: section.settings.show_description, show_second_image: section.settings.show_second_image, show_sale_badge: section.settings.show_sale_badge, show_sold_out_badge: section.settings.show_sold_out_badge, enable_quick_add: section.settings.enable_quick_add %}
        {% endfor %}
      </div>
    {% elsif request.design_mode %}
      <div class="section-editor-empty"><strong>Choose a collection</strong><span>Select a collection with products to preview this section.</span></div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name":"Featured collection",
  "tag":"section",
  "class":"section-featured-collection",
  "settings":[
    {"type":"collection","id":"collection","label":"Collection"},
    {"type":"text","id":"heading","label":"Heading","default":"Featured collection"},
    {"type":"richtext","id":"intro","label":"Intro text","default":"<p>Explore a curated selection of customer favorites.</p>"},
    {"type":"select","id":"width","label":"Content width","default":"wide","options":[{"value":"standard","label":"Standard"},{"value":"wide","label":"Wide"}]},
    {"type":"select","id":"alignment","label":"Heading alignment","default":"left","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"}]},
    {"type":"range","id":"product_limit","label":"Maximum products","min":2,"max":12,"step":1,"default":8},
    {"type":"range","id":"desktop_columns","label":"Desktop columns","min":2,"max":5,"step":1,"default":4},
    {"type":"select","id":"mobile_columns","label":"Mobile columns","default":"2","options":[{"value":"1","label":"1 column"},{"value":"2","label":"2 columns"}]},
    {"type":"header","content":"View all link"},
    {"type":"checkbox","id":"show_view_all","label":"Show View all link","default":true},
    {"type":"text","id":"view_all_label","label":"Link label","default":"View all"},
    {"type":"header","content":"Product cards"},
    {"type":"select","id":"image_ratio","label":"Image ratio","default":"square","options":[{"value":"adapt","label":"Adapt to image"},{"value":"square","label":"Square"},{"value":"portrait","label":"Portrait"},{"value":"landscape","label":"Landscape"}]},
    {"type":"select","id":"image_fit","label":"Image fit","default":"cover","options":[{"value":"cover","label":"Cover"},{"value":"contain","label":"Contain"}]},
    {"type":"select","id":"card_alignment","label":"Card text alignment","default":"left","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"}]},
    {"type":"checkbox","id":"show_vendor","label":"Show vendor","default":false},
    {"type":"checkbox","id":"show_description","label":"Show description","default":false},
    {"type":"checkbox","id":"show_second_image","label":"Show second image on hover","default":true},
    {"type":"checkbox","id":"show_sale_badge","label":"Show sale badge","default":true},
    {"type":"checkbox","id":"show_sold_out_badge","label":"Show sold out badge","default":true},
    {"type":"checkbox","id":"enable_quick_add","label":"Enable quick add","default":false},
    {"type":"header","content":"Spacing"},
    {"type":"range","id":"padding_top","label":"Top padding","min":0,"max":120,"step":8,"unit":"px","default":64},
    {"type":"range","id":"padding_bottom","label":"Bottom padding","min":0,"max":120,"step":8,"unit":"px","default":64}
  ],
  "presets":[{"name":"Featured collection"}]
}
{% endschema %}
