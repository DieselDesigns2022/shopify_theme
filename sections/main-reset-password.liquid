<section class="customer-page page-width"><h1>Reset password</h1>{% form 'reset_customer_password' %}{% if form.errors %}<div role="alert">{{ form.errors | default_errors }}</div>{% endif %}<label for="ResetPassword-{{ section.id }}">New password</label><input id="ResetPassword-{{ section.id }}" type="password" name="customer[password]" autocomplete="new-password" required><label for="ResetConfirm-{{ section.id }}">Confirm new password</label><input id="ResetConfirm-{{ section.id }}" type="password" name="customer[password_confirmation]" autocomplete="new-password" required><button class="button">Reset password</button>{% endform %}</section>{% schema %}{"name":"Reset password"}{% endschema %}
