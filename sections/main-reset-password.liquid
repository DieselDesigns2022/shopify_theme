{% render 'custom-color-scope', section: section %}
<section class="customer-page page-width"><h1>Reset password</h1>{% form 'reset_customer_password' %}{% if form.errors %}<div role="alert">{{ form.errors | default_errors }}</div>{% endif %}<label for="ResetPassword-{{ section.id }}">New password</label><input id="ResetPassword-{{ section.id }}" type="password" name="customer[password]" autocomplete="new-password" required><label for="ResetConfirm-{{ section.id }}">Confirm new password</label><input id="ResetConfirm-{{ section.id }}" type="password" name="customer[password_confirmation]" autocomplete="new-password" required><button class="button">Reset password</button>{% endform %}</section>{% schema %}
{
  "name": "Reset password",
  "settings": [
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_background_secondary",
      "label": "Secondary background",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_text",
      "label": "Text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_muted_text",
      "label": "Muted text",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "custom_heading",
      "label": "Headings",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "default": "#dddddd"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "color",
      "id": "custom_primary_button_background",
      "label": "Primary button background",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_primary_button_text",
      "label": "Primary button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_background",
      "label": "Primary button hover background",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_text",
      "label": "Primary button hover text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Forms"
    },
    {
      "type": "color",
      "id": "custom_input_background",
      "label": "Input background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_input_text",
      "label": "Input text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_input_border",
      "label": "Input border",
      "default": "#777777"
    },
    {
      "type": "color",
      "id": "custom_focus",
      "label": "Focus color",
      "default": "#2463eb"
    }
  ]
}
{% endschema %}
