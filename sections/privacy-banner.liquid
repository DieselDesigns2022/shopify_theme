{% if section.settings.enabled %}
<section id="PrivacyBanner-{{ section.id }}" class="privacy-banner privacy-banner--{{ section.settings.position }}" data-privacy-banner data-design-mode="{{ request.design_mode }}" data-days="{{ section.settings.dismiss_days }}">
  <div>{{ section.settings.message }}</div>
  {% if section.settings.policy_link != blank %}<a href="{{ section.settings.policy_link }}">Privacy policy</a>{% endif %}
  <button class="button button--secondary" type="button" data-privacy-dismiss>{{ section.settings.dismiss_label | default: 'Acknowledge' | escape }}</button>
</section>
{% endif %}
{% schema %}{"name":"Privacy notice","settings":[{"type":"checkbox","id":"enabled","label":"Enable privacy notice","default":false},{"type":"richtext","id":"message","label":"Message","default":"<p>This notice can be dismissed after it has been read.</p>"},{"type":"text","id":"dismiss_label","label":"Dismissal label","default":"Acknowledge"},{"type":"url","id":"policy_link","label":"Privacy policy link"},{"type":"select","id":"position","label":"Position","default":"bottom","options":[{"value":"bottom","label":"Bottom"},{"value":"top","label":"Top"}]},{"type":"range","id":"dismiss_days","label":"Dismissal days","min":1,"max":90,"step":1,"default":30}]}{% endschema %}
