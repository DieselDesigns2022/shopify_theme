{% render 'custom-color-scope', section: section %}
<section class="localization-section page-width">{% render 'localization-form', id: section.id %}</section>{% schema %}
{
  "name": "Localization form",
  "settings": [
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_background_secondary",
      "label": "Secondary background",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "default": "#dddddd"
    }
  ],
  "presets": [
    {
      "name": "Localization form"
    }
  ]
}
{% endschema %}
