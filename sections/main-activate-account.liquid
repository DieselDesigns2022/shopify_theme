{% render 'custom-color-scope', section: section %}
<section class="customer-page page-width"><h1>Activate account</h1>{% form 'activate_customer_password' %}{% if form.errors %}<div role="alert">{{ form.errors | default_errors }}</div>{% endif %}<label for="ActivatePassword-{{ section.id }}">Password</label><input id="ActivatePassword-{{ section.id }}" type="password" name="customer[password]" autocomplete="new-password" required><label for="ActivateConfirm-{{ section.id }}">Confirm password</label><input id="ActivateConfirm-{{ section.id }}" type="password" name="customer[password_confirmation]" autocomplete="new-password" required><button class="button">Activate account</button><button class="button button--secondary" name="decline" type="submit">Decline invitation</button>{% endform %}</section>{% schema %}
{
