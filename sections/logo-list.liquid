{% render 'custom-color-scope', section: section %}
<section class="home-section logo-list{% if section.settings.grayscale %} logo-list--grayscale{% endif %}"><div class="content-width--wide text-{{ section.settings.alignment }}">{% if section.settings.heading != blank %}<h2>{{ section.settings.heading | escape }}</h2>{% endif %}<div class="logo-list__grid" style="--desktop-columns:{{ section.settings.columns }};--mobile-columns:{{ section.settings.mobile_columns }};--logo-size:{{ section.settings.size }}px">{% for block in section.blocks %}{% assign logo_name = block.settings.name | default: block.settings.logo.alt | default: 'Partner logo' %}<div data-color-block-id="{{ block.id }}" {{ block.shopify_attributes }} class="logo-list__item">{% if block.settings.link != blank and block.settings.logo != blank %}<a href="{{ block.settings.link }}" aria-label="{{ logo_name | escape }}">{% endif %}{% if block.settings.logo != blank %}{{ block.settings.logo | image_url: width:400 | image_tag: widths:'150,300,400', sizes:'(min-width: 750px) 16vw, 40vw', loading:'lazy', alt:logo_name }}{% elsif request.design_mode %}<span class="section-placeholder">{{ logo_name | escape }}</span>{% endif %}{% if block.settings.link != blank and block.settings.logo != blank %}</a>{% endif %}</div>{% endfor %}</div></div></section>
{% schema %}
{
  "name": "Logo list",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted partners"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Desktop columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "mobile_columns",
      "label": "Mobile columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "size",
      "label": "Logo size",
      "min": 30,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "grayscale",
      "label": "Grayscale logos",
      "default": true
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_background_secondary",
      "label": "Secondary background",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_text",
      "label": "Text",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_heading",
      "label": "Headings",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "placeholder": "Inherited from theme style"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Accessible logo name",
          "default": "Partner"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo list",
      "blocks": [
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        }
      ]
    }
  ]
}
{% endschema %}