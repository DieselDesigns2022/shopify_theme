{% assign process_number = 0 %}
{% assign has_service_blocks = false %}
{% for block in section.blocks %}
  {% if block.type == '@app' %}{% assign has_service_blocks = true %}{% endif %}
  {% if block.type == 'detail' or block.type == 'process' %}{% if block.settings.heading != blank or block.settings.content != blank %}{% assign has_service_blocks = true %}{% endif %}{% endif %}
  {% if block.type == 'cta' %}{% assign has_cta_button = false %}{% if block.settings.label != blank %}{% if block.settings.link != blank %}{% assign has_cta_button = true %}{% endif %}{% endif %}{% if block.settings.heading != blank or block.settings.text != blank or has_cta_button %}{% assign has_service_blocks = true %}{% endif %}{% endif %}
{% endfor %}
<section class="service-page" style="--content-pt:{{ section.settings.top_spacing }}px;--content-pb:{{ section.settings.bottom_spacing }}px">
  <div class="page-width content-width--{{ section.settings.content_width }}">
    <header><h1>{{ page.title | escape }}</h1>{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 1800 | image_tag: widths: '600, 1000, 1400, 1800', loading: 'eager', width: section.settings.image.width, height: section.settings.image.height, alt: section.settings.image.alt }}{% endif %}</header>
    {% if page.content != blank %}<div class="rte service-page__body">{{ page.content }}</div>{% endif %}
    {% if has_service_blocks %}<div class="service-page__blocks">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'detail' %}{% if block.settings.heading != blank or block.settings.content != blank %}<div {{ block.shopify_attributes }}>{% if block.settings.heading != blank %}<h2>{{ block.settings.heading | escape }}</h2>{% endif %}{% if block.settings.content != blank %}<div class="rte">{{ block.settings.content }}</div>{% endif %}</div>{% endif %}
          {% when 'process' %}{% if block.settings.heading != blank or block.settings.content != blank %}{% assign process_number = process_number | plus: 1 %}<div class="service-process" {{ block.shopify_attributes }}><span>{{ process_number }}</span>{% if block.settings.heading != blank %}<h2>{{ block.settings.heading | escape }}</h2>{% endif %}{% if block.settings.content != blank %}<div class="rte">{{ block.settings.content }}</div>{% endif %}</div>{% endif %}
          {% when 'cta' %}{% assign has_cta_button = false %}{% if block.settings.label != blank %}{% if block.settings.link != blank %}{% assign has_cta_button = true %}{% endif %}{% endif %}{% if block.settings.heading != blank or block.settings.text != blank or has_cta_button %}<div {{ block.shopify_attributes }}>{% if block.settings.heading != blank %}<h2>{{ block.settings.heading | escape }}</h2>{% endif %}{% if block.settings.text != blank %}<div class="rte">{{ block.settings.text }}</div>{% endif %}{% if has_cta_button %}<a class="button" href="{{ block.settings.link }}">{{ block.settings.label | escape }}</a>{% endif %}</div>{% endif %}
          {% when '@app' %}<div {{ block.shopify_attributes }}>{% render block %}</div>
        {% endcase %}
      {% endfor %}
    </div>{% endif %}
  </div>
</section>
{% schema %}{"name":"Service page","settings":[{"type":"image_picker","id":"image","label":"Hero image"},{"type":"select","id":"content_width","label":"Content width","default":"standard","options":[{"value":"standard","label":"Standard"},{"value":"wide","label":"Wide"}]},{"type":"range","id":"top_spacing","label":"Top spacing","min":0,"max":96,"step":4,"unit":"px","default":48},{"type":"range","id":"bottom_spacing","label":"Bottom spacing","min":0,"max":96,"step":4,"unit":"px","default":48}],"blocks":[{"type":"detail","name":"Service detail","settings":[{"type":"text","id":"heading","label":"Heading"},{"type":"richtext","id":"content","label":"Content"}]},{"type":"process","name":"Process step","settings":[{"type":"text","id":"heading","label":"Heading"},{"type":"richtext","id":"content","label":"Content"}]},{"type":"cta","name":"Inquiry call to action","settings":[{"type":"text","id":"heading","label":"Heading"},{"type":"richtext","id":"text","label":"Text"},{"type":"text","id":"label","label":"Button label"},{"type":"url","id":"link","label":"Inquiry link"}]},{"type":"@app"}]}{% endschema %}
