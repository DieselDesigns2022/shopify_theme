{% render 'custom-color-scope', section: section %}
{% assign submit_label = section.settings.button_label | default: 'Subscribe' %}{% assign email_id = 'NewsletterEmail-' | append: section.id %}{% assign error_id = 'NewsletterError-' | append: section.id %}<section class="home-section newsletter-signup text-{{ section.settings.alignment }}"><div class="content-width--standard">{% if section.settings.heading != blank %}<h2>{{ section.settings.heading | escape }}</h2>{% endif %}{% if section.settings.text != blank %}<div>{{ section.settings.text }}</div>{% endif %}{% form 'customer', class: 'newsletter-signup__form' %}<input type="hidden" name="contact[tags]" value="newsletter"><label class="visually-hidden" for="{{ email_id }}">Email address</label><input id="{{ email_id }}" type="email" name="contact[email]" value="{{ form.email | escape }}" autocomplete="email" required placeholder="Email address"{% if form.errors %} aria-invalid="true" aria-describedby="{{ error_id }}"{% endif %}><button class="button" type="submit">{{ submit_label | escape }}</button>{% if form.posted_successfully? %}<p class="form-message--success" role="status">{{ section.settings.success | escape }}</p>{% endif %}{% if form.errors %}<div id="{{ error_id }}" class="form-message--error" role="alert">{{ form.errors | default_errors }}</div>{% endif %}{% endform %}{% if section.settings.disclaimer != blank %}<div>{{ section.settings.disclaimer }}</div>{% endif %}</div></section>
{% schema %}
{
  "name": "Newsletter signup",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay in the know"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Submit label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success",
      "label": "Success message",
      "default": "Thanks for subscribing."
    },
    {
      "type": "richtext",
      "id": "disclaimer",
      "label": "Disclaimer"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_background_secondary",
      "label": "Secondary background",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_text",
      "label": "Text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_muted_text",
      "label": "Muted text",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "custom_heading",
      "label": "Headings",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "default": "#dddddd"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "color",
      "id": "custom_primary_button_background",
      "label": "Primary button background",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_primary_button_text",
      "label": "Primary button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_background",
      "label": "Primary button hover background",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_text",
      "label": "Primary button hover text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Forms"
    },
    {
      "type": "color",
      "id": "custom_input_background",
      "label": "Input background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_input_text",
      "label": "Input text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_input_border",
      "label": "Input border",
      "default": "#777777"
    },
    {
      "type": "color",
      "id": "custom_focus",
      "label": "Focus color",
      "default": "#2463eb"
    }
  ],
  "presets": [
    {
      "name": "Newsletter signup"
    }
  ]
}
{% endschema %}
