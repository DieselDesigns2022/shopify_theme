{% render 'custom-color-scope', section: section %}
<section class="main-article" style="--content-pt:{{ section.settings.top_spacing }}px;--content-pb:{{ section.settings.bottom_spacing }}px"><article class="page-width content-width--{{ section.settings.content_width }}"><header class="article-header"><a href="{{ blog.url }}">{{ blog.title | escape }}</a><h1>{{ article.title | escape }}</h1><p class="article-meta">{{ article.author | escape }} · {{ article.published_at | date: '%B %-d, %Y' }}</p>{% if article.tags.size > 0 %}<p class="article-tags">{% for tag in article.tags %}<a href="{{ blog.url }}/tagged/{{ tag | handle }}">{{ tag | escape }}</a>{% endfor %}</p>{% endif %}</header>{% if article.image != blank %}<figure class="article-featured-image">{{ article.image | image_url: width: 2000 | image_tag: widths: '600, 900, 1200, 1600, 2000', loading: 'eager', width: article.image.width, height: article.image.height, alt: article.image.alt }}</figure>{% endif %}<div class="rte article-body">{{ article.content }}</div>{% render 'social-sharing', article: article %}{% for block in section.blocks %}{% if block.type == '@app' %}<div data-color-block-id="{{ block.id }}" {{ block.shopify_attributes }}>{% render block %}</div>{% endif %}{% endfor %}{% if blog.comments_enabled? %}<section class="article-comments"><h2>Comments</h2>{% paginate article.comments by 10 %}{% for comment in article.comments %}<article class="article-comment"><h3>{{ comment.author | escape }}</h3><p>{{ comment.created_at | date: '%B %-d, %Y' }}</p><div class="rte">{{ comment.content }}</div></article>{% else %}<p>No comments yet.</p>{% endfor %}{% render 'pagination', paginate: paginate %}{% endpaginate %}{% assign comment_form_id = 'CommentForm-' | append: section.id %}{% form 'new_comment', article, id: comment_form_id %}{% if form.posted_successfully? %}<p class="form-success" role="status">Your comment was submitted and may appear after approval.</p>{% endif %}{% if form.errors %}<div class="form-errors" role="alert">{{ form.errors | default_errors }}</div>{% endif %}<p><label for="CommentAuthor-{{ section.id }}">Name <span aria-hidden="true">*</span></label><input id="CommentAuthor-{{ section.id }}" type="text" name="comment[author]" value="{{ form.author | escape }}" required></p><p><label for="CommentEmail-{{ section.id }}">Email <span aria-hidden="true">*</span></label><input id="CommentEmail-{{ section.id }}" type="email" name="comment[email]" value="{{ form.email | escape }}" required></p><p><label for="CommentBody-{{ section.id }}">Comment <span aria-hidden="true">*</span></label><textarea id="CommentBody-{{ section.id }}" name="comment[body]" required>{{ form.body | escape }}</textarea></p><button class="button" type="submit">Post comment</button>{% endform %}</section>{% endif %}<nav class="article-navigation" aria-label="Article navigation">{% if article.previous_article %}<a href="{{ article.previous_article.url }}">Previous: {{ article.previous_article.title | escape }}</a>{% endif %}{% if article.next_article %}<a href="{{ article.next_article.url }}">Next: {{ article.next_article.title | escape }}</a>{% endif %}</nav></article></section>
{% schema %}
{
  "name": "Article",
  "settings": [
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "standard",
          "label": "Standard"
        }
      ]
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top spacing",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_background_secondary",
      "label": "Secondary background",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_text",
      "label": "Text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_muted_text",
      "label": "Muted text",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "custom_heading",
      "label": "Headings",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "default": "#dddddd"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "color",
      "id": "custom_primary_button_background",
      "label": "Primary button background",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_primary_button_text",
      "label": "Primary button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_background",
      "label": "Primary button hover background",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_text",
      "label": "Primary button hover text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Forms"
    },
    {
      "type": "color",
      "id": "custom_input_background",
      "label": "Input background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_input_text",
      "label": "Input text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_input_border",
      "label": "Input border",
      "default": "#777777"
    },
    {
      "type": "color",
      "id": "custom_focus",
      "label": "Focus color",
      "default": "#2463eb"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
