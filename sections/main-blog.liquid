{% render 'custom-color-scope', section: section %}
{% paginate blog.articles by section.settings.articles_per_page %}
{% assign featured = section.settings.featured_article %}
<section class="main-blog" style="--content-pt:{{ section.settings.top_spacing }}px;--content-pb:{{ section.settings.bottom_spacing }}px">
  <div class="page-width content-width--{{ section.settings.content_width }}">
    <header class="blog-header">{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 1800 | image_tag: widths: '600, 1000, 1400, 1800', loading: 'eager', width: section.settings.image.width, height: section.settings.image.height, alt: section.settings.image.alt }}{% endif %}<h1>{{ blog.title | escape }}</h1>{% if section.settings.intro != blank %}<div class="rte">{{ section.settings.intro }}</div>{% endif %}{% if blog.all_tags.size > 0 %}<nav class="blog-tags" aria-label="Blog tags">{% for tag in blog.all_tags %}<a href="{{ blog.url }}/tagged/{{ tag | handle }}">{{ tag | escape }}</a>{% endfor %}</nav>{% endif %}</header>
    {% if section.settings.show_featured_article and featured != blank %}<div class="blog-featured">{% render 'article-card', article: featured, show_image: true, show_meta: section.settings.show_metadata, show_author: section.settings.show_author, show_excerpt: section.settings.show_excerpt, show_tags: section.settings.show_tags, image_loading: 'eager' %}</div>{% endif %}
    {% assign regular_count = 0 %}{% for article in blog.articles %}{% assign is_featured = false %}{% if section.settings.show_featured_article and featured != blank %}{% if article.id == featured.id %}{% assign is_featured = true %}{% endif %}{% endif %}{% unless is_featured %}{% assign regular_count = regular_count | plus: 1 %}{% endunless %}{% endfor %}
    {% if regular_count > 0 %}<div class="article-grid article-grid--{{ section.settings.columns }}">{% for article in blog.articles %}{% unless section.settings.show_featured_article and featured != blank and article.id == featured.id %}{% render 'article-card', article: article, show_image: true, show_meta: section.settings.show_metadata, show_author: section.settings.show_author, show_excerpt: section.settings.show_excerpt, show_tags: section.settings.show_tags, image_loading: 'lazy' %}{% endunless %}{% endfor %}</div>{% endif %}
    {% if paginate.pages > 1 %}{% render 'pagination', paginate: paginate %}{% endif %}
    {% if regular_count == 0 %}{% assign has_featured_output = false %}{% if section.settings.show_featured_article %}{% if featured != blank %}{% assign has_featured_output = true %}{% endif %}{% endif %}{% unless has_featured_output %}<p class="content-empty">There are no articles in this blog yet.</p>{% endunless %}{% endif %}
  </div>
</section>
{% endpaginate %}
{% schema %}
{
  "name": "Blog",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner image"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introductory text"
    },
    {
      "type": "article",
      "id": "featured_article",
      "label": "Featured article"
    },
    {
      "type": "checkbox",
      "id": "show_featured_article",
      "label": "Show featured article",
      "default": false
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "default": "wide",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "default": "3",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        }
      ]
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles per page",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 9
    },
    {
      "type": "checkbox",
      "id": "show_metadata",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show tags",
      "default": false
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top spacing",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_background_secondary",
      "label": "Secondary background",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_text",
      "label": "Text",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_muted_text",
      "label": "Muted text",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_heading",
      "label": "Headings",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "color",
      "id": "custom_card_background",
      "label": "Card background",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_card_text",
      "label": "Card text",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_card_heading",
      "label": "Card heading",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_card_border",
      "label": "Card border",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_card_link",
      "label": "Card link",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_card_link_hover",
      "label": "Card link hover",
      "placeholder": "Inherited from theme style"
    }
  ]
}
{% endschema %}
