      "id": "custom_card_link_hover",
      "label": "Card link hover",
      "default": "#555555"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
