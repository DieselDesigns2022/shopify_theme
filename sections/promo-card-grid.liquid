    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "color",
      "id": "custom_card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_card_text",
      "label": "Card text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_card_heading",
      "label": "Card heading",
