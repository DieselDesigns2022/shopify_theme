          "label": "Button link"
        },
        {
          "type": "header",
          "content": "Custom block colors"
        },
        {
          "type": "checkbox",
          "id": "use_custom_block_colors",
          "label": "Use custom block colors",
          "default": false
        },
        {
          "type": "color",
          "id": "block_text_color",
          "label": "Text",
          "default": "#222222"
        },
        {
          "type": "color",
          "id": "block_heading_color",
