{% render 'custom-color-scope', section: section %}
{% assign valid_count = 0 %}
{% for block in section.blocks %}
  {% if block.settings.question != blank and block.settings.answer != blank %}
    {% assign valid_count = valid_count | plus: 1 %}
  {% endif %}
{% endfor %}
{% if section.settings.heading != blank or section.settings.intro != blank or valid_count > 0 %}
  <section class="faq-section" data-faq-section data-single-open="{{ section.settings.single_open }}" style="--content-pt:{{ section.settings.top_spacing }}px;--content-pb:{{ section.settings.bottom_spacing }}px">
    <div class="page-width content-width--{{ section.settings.content_width }} faq-section__inner faq-section__inner--{{ section.settings.alignment }}">
      {% if section.settings.heading != blank %}<h2>{{ section.settings.heading | escape }}</h2>{% endif %}
      {% if section.settings.intro != blank %}<div class="rte">{{ section.settings.intro }}</div>{% endif %}
      {% if valid_count > 0 %}
        <div class="faq-section__items">
          {% assign rendered_count = 0 %}
          {% for block in section.blocks %}
            {% if block.settings.question != blank and block.settings.answer != blank %}
              {% assign rendered_count = rendered_count | plus: 1 %}
              <details class="faq-item"{% if block.settings.open_by_default %} open{% elsif rendered_count == 1 and section.settings.open_first %} open{% endif %} data-color-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
                <summary>
                  {% if block.settings.category != blank %}<span class="faq-item__category">{{ block.settings.category | escape }}</span>{% endif %}
                  {{ block.settings.question | escape }}
                </summary>
                <div class="rte faq-item__answer">{{ block.settings.answer }}</div>
              </details>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </section>
{% endif %}
{% if valid_count > 0 %}
  <script type="application/ld+json">
    {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{% assign faq_schema_count = 0 %}{% for block in section.blocks %}{% if block.settings.question != blank and block.settings.answer != blank %}{% if faq_schema_count > 0 %},{% endif %}{"@type":"Question","name":{{ block.settings.question | json }},"acceptedAnswer":{"@type":"Answer","text":{{ block.settings.answer | strip_html | json }}}}{% assign faq_schema_count = faq_schema_count | plus: 1 %}{% endif %}{% endfor %}]}
  </script>
{% endif %}
{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introductory text"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "standard",
          "label": "Standard"
        }
      ]
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "single_open",
      "label": "Keep one item open at a time",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first item by default",
      "default": false
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top spacing",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_text",
      "label": "Text",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_muted_text",
      "label": "Muted text",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_heading",
      "label": "Headings",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "placeholder": "Inherited from theme style"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "placeholder": "Inherited from theme style"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Open by default",
          "default": false
        },
        {
          "type": "header",
          "content": "Custom block colors"
        },
        {
          "type": "color",
          "id": "block_text_color",
          "label": "Text",
          "placeholder": "Inherited from theme style"
        },
        {
          "type": "color",
          "id": "block_heading_color",
          "label": "Heading",
          "placeholder": "Inherited from theme style"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ"
    }
  ]
}
{% endschema %}
