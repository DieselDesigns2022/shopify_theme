{% render 'custom-color-scope', section: section %}
<section class="main-404 page-width">
  <div class="main-404__inner">
    <p class="main-404__code">404</p>
    <h1>{{ section.settings.heading | escape }}</h1>
    {% if section.settings.text != blank %}<div>{{ section.settings.text }}</div>{% endif %}
    <a class="button" href="{{ routes.root_url }}">{{ section.settings.button_label | escape }}</a>
    {% if section.settings.show_search_link %}<a class="main-404__search" href="{{ routes.search_url }}">{{ 'search.search' | t }}</a>{% endif %}
  </div>
</section>
{% schema %}
{
  "name": "404 page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page not found"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>The page you were looking for does not exist. Return home or search the store.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Return home"
    },
    {
      "type": "checkbox",
      "id": "show_search_link",
      "label": "Show search link",
      "default": true
    },
    {
      "type": "header",
      "content": "Custom colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "color",
      "id": "custom_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Text and links"
    },
    {
      "type": "color",
      "id": "custom_text",
      "label": "Text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_heading",
      "label": "Headings",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "custom_link",
      "label": "Links",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_link_hover",
      "label": "Link hover",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "custom_border",
      "label": "Borders and dividers",
      "default": "#dddddd"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "color",
      "id": "custom_primary_button_background",
      "label": "Primary button background",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "custom_primary_button_text",
      "label": "Primary button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_background",
      "label": "Primary button hover background",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "custom_primary_button_hover_text",
      "label": "Primary button hover text",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
