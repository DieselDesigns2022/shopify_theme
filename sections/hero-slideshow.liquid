{% assign section_position = section.index | default: 999 %}
<section id="Hero-{{ section.id }}" class="home-section hero-slideshow{% if section.settings.width == 'page' %} page-width{% endif %}" data-slideshow data-autoplay="{{ section.settings.autoplay }}" data-speed="{{ section.settings.speed }}" data-has-controls="{% if section.settings.arrows or section.settings.pagination %}true{% else %}false{% endif %}" style="--hero-height:{{ section.settings.height }}px;--hero-mobile-height:{{ section.settings.mobile_height }}px" role="region" aria-roledescription="carousel" aria-label="{{ section.settings.label | default: 'Featured promotions' | escape }}" data-section-id="{{ section.id }}">
  {% if section.blocks.size == 0 %}<div class="hero-slideshow__slide"><div class="hero-slideshow__content"><h2>Add slideshow slides</h2></div></div>{% endif %}
  {% for block in section.blocks %}{% assign hero_loading = 'lazy' %}{% assign hero_priority = 'auto' %}{% if forloop.first and section_position <= 2 %}{% assign hero_loading = 'eager' %}{% assign hero_priority = 'high' %}{% endif %}{% assign fallback = block.settings.image | default: block.settings.mobile_image %}<article class="hero-slideshow__slide" data-slide {{ block.shopify_attributes }} role="group" aria-roledescription="slide" aria-label="Slide {{ forloop.index }} of {{ forloop.length }}" style="--hero-fallback:{{ block.settings.background }};--hero-overlay:{{ block.settings.overlay }};--hero-overlay-opacity:{{ block.settings.opacity | divided_by: 100.0 }};color:{{ block.settings.text_color }}">{% if fallback != blank %}<picture class="hero-slideshow__media">{% if block.settings.mobile_image != blank %}<source media="(max-width: 749px)" srcset="{{ block.settings.mobile_image | image_url: width: 375 }} 375w, {{ block.settings.mobile_image | image_url: width: 750 }} 750w, {{ block.settings.mobile_image | image_url: width: 900 }} 900w">{% endif %}{{ fallback | image_url: width: 2400 | image_tag: widths: '750,1200,1800,2400', sizes: '100vw', loading: hero_loading, fetchpriority: hero_priority }}</picture>{% endif %}<span class="hero-slideshow__overlay" aria-hidden="true"></span><div class="hero-slideshow__content hero-slideshow__content--{{ block.settings.alignment }}" style="--hero-position:{{ block.settings.position }};color:{{ block.settings.text_color }}">{% if block.settings.eyebrow != blank %}<p>{{ block.settings.eyebrow | escape }}</p>{% endif %}{% if block.settings.heading != blank %}<h2>{{ block.settings.heading | escape }}</h2>{% endif %}{% if block.settings.text != blank %}<div>{{ block.settings.text }}</div>{% endif %}<div class="button-group">{% if block.settings.primary_label != blank and block.settings.primary_link != blank %}<a class="button" href="{{ block.settings.primary_link }}">{{ block.settings.primary_label | escape }}</a>{% endif %}{% if block.settings.secondary_label != blank and block.settings.secondary_link != blank %}<a class="button button--text" href="{{ block.settings.secondary_link }}">{{ block.settings.secondary_label | escape }}</a>{% endif %}</div></div></article>{% endfor %}
  {% if section.blocks.size > 1 and section.settings.arrows or section.blocks.size > 1 and section.settings.pagination %}<div class="hero-slideshow__controls">{% if section.settings.arrows %}<button type="button" class="hero-slideshow__arrow" data-slide-prev aria-label="Previous slide">‹</button>{% endif %}<div class="hero-slideshow__pagination">{% if section.settings.pagination %}{% for block in section.blocks %}<button type="button" data-slide-to="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>{% endfor %}{% endif %}</div>{% if section.settings.autoplay %}<button type="button" class="hero-slideshow__rotation" data-slideshow-rotation data-pause-label="Pause slideshow" data-play-label="Play slideshow" aria-pressed="false">Pause slideshow</button>{% endif %}{% if section.settings.arrows %}<button type="button" class="hero-slideshow__arrow" data-slide-next aria-label="Next slide">›</button>{% endif %}</div><p class="hero-slideshow__status" data-slideshow-status aria-live="polite"></p>{% endif %}
</section>
{% schema %}{"name":"Hero slideshow","max_blocks":6,"settings":[{"type":"text","id":"label","label":"Accessible label","default":"Featured promotions"},{"type":"select","id":"width","label":"Width","default":"full","options":[{"value":"full","label":"Full width"},{"value":"page","label":"Page width"}]},{"type":"checkbox","id":"autoplay","label":"Autoplay","default":true},{"type":"range","id":"speed","label":"Autoplay speed","min":3,"max":10,"step":1,"unit":"s","default":5},{"type":"checkbox","id":"arrows","label":"Show arrows","default":true},{"type":"checkbox","id":"pagination","label":"Show pagination","default":true},{"type":"range","id":"height","label":"Desktop height","min":300,"max":800,"step":20,"unit":"px","default":560},{"type":"range","id":"mobile_height","label":"Mobile height","min":240,"max":640,"step":20,"unit":"px","default":420}],"blocks":[{"type":"slide","name":"Slide","settings":[{"type":"image_picker","id":"image","label":"Desktop image"},{"type":"image_picker","id":"mobile_image","label":"Mobile image"},{"type":"text","id":"eyebrow","label":"Eyebrow"},{"type":"text","id":"heading","label":"Heading","default":"New season, new ideas"},{"type":"richtext","id":"text","label":"Text"},{"type":"text","id":"primary_label","label":"Primary button label"},{"type":"url","id":"primary_link","label":"Primary button link"},{"type":"text","id":"secondary_label","label":"Secondary button label"},{"type":"url","id":"secondary_link","label":"Secondary button link"},{"type":"select","id":"position","label":"Content position","default":"center","options":[{"value":"start","label":"Top"},{"value":"center","label":"Center"},{"value":"end","label":"Bottom"}]},{"type":"select","id":"alignment","label":"Text alignment","default":"left","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}]},{"type":"color","id":"text_color","label":"Text color","default":"#ffffff"},{"type":"color","id":"overlay","label":"Overlay color","default":"#000000"},{"type":"range","id":"opacity","label":"Overlay opacity","min":0,"max":80,"step":5,"unit":"%","default":25},{"type":"color","id":"background","label":"Fallback background","default":"#555555"}]}],"presets":[{"name":"Hero slideshow","blocks":[{"type":"slide"},{"type":"slide"}]}]}{% endschema %}
