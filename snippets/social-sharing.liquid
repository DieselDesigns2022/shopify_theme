{% assign share_url = canonical_url | url_encode %}
{% assign share_title = article.title | default: page.title | url_encode %}
<nav class="social-sharing" aria-label="Share this page">
  <a href="https://www.facebook.com/sharer/sharer.php?u={{ share_url }}" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">Facebook</a>
  <a href="https://twitter.com/intent/tweet?url={{ share_url }}&text={{ share_title }}" target="_blank" rel="noopener noreferrer" aria-label="Share on X">X</a>
  {% if article.image != blank %}
    <a href="https://pinterest.com/pin/create/button/?url={{ share_url }}&media={{ article.image | image_url: width: 1200 | url_encode }}&description={{ share_title }}" target="_blank" rel="noopener noreferrer" aria-label="Share on Pinterest">Pinterest</a>
  {% endif %}
  <a href="mailto:?subject={{ share_title }}&body={{ share_url }}" aria-label="Share by email">Email</a>
  <button type="button" data-copy-link data-copy-url="{{ canonical_url | escape }}" hidden>Copy link</button>
  <span data-copy-status aria-live="polite"></span>
</nav>
