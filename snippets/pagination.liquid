{% if paginate.pages > 1 %}<nav class="pagination" aria-label="Pagination"><ul>{% if paginate.previous %}<li><a href="{{ paginate.previous.url }}">Previous</a></li>{% endif %}{% for part in paginate.parts %}<li>{% if part.is_link %}<a href="{{ part.url }}">{{ part.title }}</a>{% elsif part.title == paginate.current_page %}<span aria-current="page">{{ part.title }}</span>{% else %}<span>{{ part.title }}</span>{% endif %}</li>{% endfor %}{% if paginate.next %}<li><a href="{{ paginate.next.url }}">Next</a></li>{% endif %}</ul></nav>{% endif %}
