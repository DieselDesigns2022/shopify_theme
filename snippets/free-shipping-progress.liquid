{% liquid
  assign threshold_cents = threshold | times: 100 | round
  assign total = cart.total_price | plus: 0
  assign progress = 0
  if threshold_cents > 0
    assign progress = total | times: 100 | divided_by: threshold_cents
    if progress > 100
      assign progress = 100
    endif
  endif
%}
{% if enabled and threshold_cents > 0 %}
  <section class="free-shipping-progress" aria-label="{{ heading | default: 'Free-shipping progress' | escape }}">
    {% if heading != blank %}<h2>{{ heading | escape }}</h2>{% endif %}
    {% if total >= threshold_cents %}
      <p class="free-shipping-progress__message" role="status">{{ success_message | default: 'You may qualify for free shipping.' | escape }}</p>
    {% else %}
      {% assign remaining = threshold_cents | minus: total %}
      {% assign remaining_money = remaining | money %}
      <p class="free-shipping-progress__message">{{ progress_message | default: 'You’re {{ amount }} away from the free-shipping threshold.' | replace: '{{ amount }}', remaining_money | escape }}</p>
    {% endif %}
    <div class="free-shipping-progress__track" role="progressbar" aria-label="{{ heading | default: 'Free-shipping progress' | escape }}" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{ progress }}"><span class="free-shipping-progress__bar" style="--free-shipping-progress: {{ progress }}%"></span></div>
  </section>
{% endif %}
