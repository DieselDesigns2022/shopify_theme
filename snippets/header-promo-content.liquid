{% liquid
  assign render_context = context | default: 'desktop'
  assign has_promo_button = false
  if block.settings.promo_link != blank and block.settings.promo_button_label != blank
    assign has_promo_button = true
  endif
  assign has_non_image_promo = false
  if block.settings.sale_callout != blank or block.settings.promo_heading != blank or block.settings.promo_text != blank or block.settings.featured_collection != blank or block.settings.featured_product != blank or has_promo_button
    assign has_non_image_promo = true
  endif
  assign has_context_image = false
  if block.settings.promo_image != blank
    if render_context == 'mobile' and block.settings.show_promo_mobile
      assign has_context_image = true
    elsif render_context != 'mobile' and block.settings.show_promo_desktop
      assign has_context_image = true
    endif
  endif
  assign has_promo = false
  if has_non_image_promo or has_context_image
    assign has_promo = true
  endif
%}
{% if has_promo %}
  <div class="{{ class | default: 'mega-menu__promo' }}" aria-label="{{ 'header.mega_menu_promo' | t }}">
    {% if has_context_image %}<div class="mega-menu__promo-image mega-menu__promo-image--desktop-{{ block.settings.show_promo_desktop }} mega-menu__promo-image--mobile-{{ block.settings.show_promo_mobile }}">{{ block.settings.promo_image | image_url: width: 520 | image_tag: loading: 'lazy', widths: '260, 360, 520', sizes: '(min-width: 750px) 320px, 90vw' }}</div>{% endif %}
    {% if block.settings.sale_callout != blank %}<p class="mega-menu__sale">{{ block.settings.sale_callout | escape }}</p>{% endif %}
    {% if block.settings.promo_heading != blank %}<h3>{{ block.settings.promo_heading | escape }}</h3>{% endif %}
    {% if block.settings.promo_text != blank %}<p>{{ block.settings.promo_text | escape }}</p>{% endif %}
    {% if block.settings.featured_collection != blank %}<a href="{{ block.settings.featured_collection.url }}">{{ block.settings.featured_collection.title | escape }}</a>{% endif %}
    {% if block.settings.featured_product != blank %}<a href="{{ block.settings.featured_product.url }}">{{ block.settings.featured_product.title | escape }}</a>{% endif %}
    {% if has_promo_button %}<a class="button" href="{{ block.settings.promo_link }}">{{ block.settings.promo_button_label | escape }}</a>{% endif %}
  </div>
{% endif %}
