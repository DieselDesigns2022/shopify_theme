{% liquid
  assign card_product = product
  assign card_image = card_product.featured_image
  assign second_image = card_product.images[1]
  assign card_ratio = image_ratio | default: 'adapt'
  assign card_fit = image_fit | default: 'cover'
  assign card_alignment = text_alignment | default: 'left'
  assign card_sale = false
  assign card_media_ratio = 1
  assign available_variant_count = 0
  assign only_available_variant = nil
  if card_image != blank
    assign card_media_ratio = card_image.aspect_ratio
  endif
  for variant in card_product.variants
    if variant.compare_at_price > variant.price
      assign card_sale = true
    endif
    if variant.available
      assign available_variant_count = available_variant_count | plus: 1
      assign only_available_variant = variant
    endif
  endfor
%}
<article class="product-card card product-card--{{ card_alignment }}">
  <div class="product-card__media product-card__media--{{ card_ratio }} product-card__media--{{ card_fit }}" style="--product-card-ratio: {{ card_media_ratio }}">
    {% if show_sold_out_badge and card_product.available == false %}<span class="product-card__badge badge--sold-out">Sold out</span>{% elsif show_sale_badge and card_sale %}<span class="product-card__badge">Sale</span>{% endif %}
    {% if card_image != blank %}
      <a class="product-card__image-link" href="{{ card_product.url }}" aria-label="View {{ card_product.title | escape }}">
        {{ card_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '240, 360, 540, 720, 900', sizes: '(min-width: 750px) 25vw, 50vw', alt: card_image.alt | default: card_product.title | escape, class: 'product-card__image' }}
        {% if show_second_image and second_image != blank %}{{ second_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '240, 360, 540, 720, 900', sizes: '(min-width: 750px) 25vw, 50vw', alt: second_image.alt | default: card_product.title | escape, class: 'product-card__image product-card__image--secondary' }}{% endif %}
      </a>
    {% else %}
      <div class="product-card__placeholder" role="img" aria-label="{{ card_product.title | escape }} image unavailable">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
    {% endif %}
  </div>
  <div class="product-card__content">
    {% if show_vendor and card_product.vendor != blank %}<p class="product-card__vendor">{{ card_product.vendor | escape }}</p>{% endif %}
    {% if show_product_type and card_product.type != blank %}<p class="product-card__type">{{ card_product.type | escape }}</p>{% endif %}
    <h3 class="product-card__title"><a href="{{ card_product.url }}">{{ card_product.title | escape }}</a></h3>
    {% render 'price', product: card_product, show_from: true %}
    {% if show_description and card_product.description != blank %}<p class="product-card__description">{{ card_product.description | strip_html | truncate: 120 | escape }}</p>{% endif %}
    {% if enable_quick_add %}
      {% if available_variant_count == 1 %}{% form 'product', card_product, class: 'product-card__quick-add', data-cart-quick-add: '' %}<input type="hidden" name="id" value="{{ only_available_variant.id }}"><button class="button button--secondary" type="submit">Add to cart</button><p class="product-card__quick-add-status" data-quick-add-status role="status" aria-live="polite"></p>{% endform %}
      {% elsif available_variant_count > 1 %}<a class="button button--secondary product-card__choose" href="{{ card_product.url }}">Choose options</a>{% endif %}
    {% endif %}
  </div>
</article>
