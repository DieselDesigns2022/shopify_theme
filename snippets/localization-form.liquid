{% assign localization_id = id | default: section.id | default: 'footer' %}
{% if localization.available_countries.size > 1 or localization.available_languages.size > 1 %}
  {% form 'localization', id: 'LocalizationForm-' | append: localization_id, class: 'localization-form', data-localization-form: '' %}
    {% if localization.available_countries.size > 1 %}<div class="field"><label for="LocalizationCountry-{{ localization_id }}">Country / region</label><select id="LocalizationCountry-{{ localization_id }}" name="country_code" data-localization-select>{% for country in localization.available_countries %}<option value="{{ country.iso_code }}"{% if country.iso_code == localization.country.iso_code %} selected{% endif %}>{{ country.name | escape }} ({{ country.currency.iso_code | escape }} {{ country.currency.symbol | escape }})</option>{% endfor %}</select></div>{% endif %}
    {% if localization.available_languages.size > 1 %}<div class="field"><label for="LocalizationLanguage-{{ localization_id }}">Language</label><select id="LocalizationLanguage-{{ localization_id }}" name="language_code" data-localization-select>{% for language in localization.available_languages %}<option value="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} selected{% endif %}>{{ language.endonym_name | escape }}</option>{% endfor %}</select></div>{% endif %}
    <button class="button button--secondary" type="submit">Update preferences</button>
  {% endform %}
{% endif %}
