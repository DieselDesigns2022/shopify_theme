<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% render 'meta-tags' %}
    {% capture search_action_placeholder %}{search_term_string}{% endcapture %}
    {% assign search_action_target = shop.url | append: routes.search_url | append: '?q=' | append: search_action_placeholder %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {"@type":"Organization","name":{{ shop.name | json }},"url":{{ shop.url | append: routes.root_url | json }}},
        {"@type":"WebSite","name":{{ shop.name | json }},"url":{{ shop.url | append: routes.root_url | json }},"potentialAction":{"@type":"SearchAction","target":{{ search_action_target | json }},"query-input":"required name=search_term_string"}}
      ]
    }
    </script>
    {% if request.page_type == 'product' %}
    <script type="application/ld+json">
    {
      "@context":"https://schema.org",
      "@type":"Product",
      "name":{{ product.title | json }},
      "url":{{ canonical_url | json }}{% if product.description != blank %},
      "description":{{ product.description | strip_html | json }}{% endif %}{% if product.featured_image != blank %},
      "image":{{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}{% endif %}{% if product.vendor != blank %},
      "brand":{"@type":"Brand","name":{{ product.vendor | json }}}{% endif %},
      "offers":{"@type":"AggregateOffer","lowPrice":{{ product.price_min | divided_by: 100.0 | json }},"highPrice":{{ product.price_max | divided_by: 100.0 | json }},"offerCount":{{ product.variants.size | json }},"priceCurrency":{{ cart.currency.iso_code | default: shop.currency | json }},"availability":{% if product.available %}"https://schema.org/InStock"{% else %}"https://schema.org/OutOfStock"{% endif %},"url":{{ canonical_url | json }}}
    }
    </script>
    {% endif %}
    {% if request.page_type == 'article' %}
    <script type="application/ld+json">
    {"@context":"https://schema.org","@type":"BlogPosting","headline":{{ article.title | json }},"mainEntityOfPage":{{ canonical_url | json }},"datePublished":{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},"author":{"@type":"Person","name":{{ article.author | json }}}{% if article.image != blank %},"image":{{ article.image | image_url: width: 1200 | prepend: 'https:' | json }}{% endif %}}
    </script>
    {% endif %}
    {% if settings.favicon != blank %}<link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">{% endif %}
    {{ content_for_header }}
    {% assign body_font = settings.font_body %}{% assign heading_font = settings.font_heading %}{% assign button_font = settings.font_body %}{% assign navigation_font = settings.font_body %}
    {% assign body_font_weight = settings.body_font_weight | plus: 0 %}{% assign heading_font_weight = settings.heading_font_weight | plus: 0 %}{% assign button_font_weight = settings.button_font_weight | plus: 0 %}{% assign navigation_font_weight = settings.navigation_font_weight | plus: 0 %}
    {% assign body_weight_font = body_font | font_modify: 'weight', body_font_weight %}{% assign heading_weight_font = heading_font | font_modify: 'weight', heading_font_weight %}{% assign button_weight_font = button_font | font_modify: 'weight', button_font_weight %}{% assign navigation_weight_font = navigation_font | font_modify: 'weight', navigation_font_weight %}
    <style>
      {% if body_font != blank %}{{ body_font | font_face: font_display: 'swap' }}{% endif %}
      {% if body_weight_font != blank and body_weight_font != body_font %}{{ body_weight_font | font_face: font_display: 'swap' }}{% endif %}
      {% if heading_font != blank and heading_font != body_font %}{{ heading_font | font_face: font_display: 'swap' }}{% endif %}
      {% if heading_weight_font != blank and heading_weight_font != heading_font and heading_weight_font != body_font and heading_weight_font != body_weight_font %}{{ heading_weight_font | font_face: font_display: 'swap' }}{% endif %}
      {% if button_font != blank and button_font != body_font and button_font != heading_font %}{{ button_font | font_face: font_display: 'swap' }}{% endif %}
      {% if button_weight_font != blank and button_weight_font != button_font and button_weight_font != body_font and button_weight_font != body_weight_font and button_weight_font != heading_font and button_weight_font != heading_weight_font %}{{ button_weight_font | font_face: font_display: 'swap' }}{% endif %}
      {% if navigation_font != blank and navigation_font != body_font and navigation_font != heading_font and navigation_font != button_font %}{{ navigation_font | font_face: font_display: 'swap' }}{% endif %}
      {% if navigation_weight_font != blank and navigation_weight_font != navigation_font and navigation_weight_font != body_font and navigation_weight_font != body_weight_font and navigation_weight_font != heading_font and navigation_weight_font != heading_weight_font and navigation_weight_font != button_font and navigation_weight_font != button_weight_font %}{{ navigation_weight_font | font_face: font_display: 'swap' }}{% endif %}
      :root {
        /* Phase 4 global design tokens */
        --color-background: {{ settings.color_background }};
        --color-background-secondary: {{ settings.color_background_secondary }};
        --color-text: {{ settings.color_text }};
        --color-text-muted: {{ settings.color_text_muted }};
        --color-heading: {{ settings.color_heading }};
        --color-border: {{ settings.color_border }};
        --color-link: {{ settings.color_link }};
        --color-link-hover: {{ settings.color_link_hover }};
        --color-button-primary-bg: {{ settings.color_button_primary_bg }};
        --color-button-primary-text: {{ settings.color_button_primary_text }};
        --color-button-primary-hover-bg: {{ settings.color_button_primary_hover_bg }};
        --color-button-primary-hover-text: {{ settings.color_button_primary_hover_text }};
        --color-button-secondary-bg: {{ settings.color_button_secondary_bg }};
        --color-button-secondary-text: {{ settings.color_button_secondary_text }};
        --color-button-secondary-border: {{ settings.color_button_secondary_border }};
        --color-button-secondary-hover-bg: {{ settings.color_button_secondary_hover_bg }};
        --color-button-secondary-hover-text: {{ settings.color_button_secondary_hover_text }};
        --color-input-background: {{ settings.color_input_background }};
        --color-input-text: {{ settings.color_input_text }};
        --color-input-border: {{ settings.color_input_border }};
        --color-placeholder: {{ settings.color_placeholder }};
        --color-focus: {{ settings.color_focus }};
        --color-sale: {{ settings.color_sale }};
        --color-error: {{ settings.color_error }};
        --color-success: {{ settings.color_success }};
        --color-sold-out: {{ settings.color_sold_out }};
        --color-badge-bg: {{ settings.color_badge_bg }};
        --color-badge-text: {{ settings.color_badge_text }};
        --color-footer-bg: {{ settings.color_footer_bg }};
        --color-footer-text: {{ settings.color_footer_text }};
        --font-body-family: {{ settings.font_body.family | default: 'system-ui' }}, {{ settings.font_body.fallback_families | default: 'sans-serif' }};
        --font-heading-family: {{ settings.font_heading.family | default: 'system-ui' }}, {{ settings.font_heading.fallback_families | default: 'sans-serif' }};
        --font-button-family: var(--font-body-family);
        --font-navigation-family: var(--font-body-family);
        --base-font-size: {{ settings.base_font_size }}px;
        --line-height: {{ settings.line_height }};
        --heading-line-height: {{ settings.heading_line_height }};
        --heading-scale: {{ settings.heading_scale | divided_by: 100.0 }};
        --body-font-weight: {{ settings.body_font_weight }};
        --heading-font-weight: {{ settings.heading_font_weight }};
        --body-letter-spacing: {{ settings.body_letter_spacing | divided_by: 100.0 }}em;
        --heading-letter-spacing: {{ settings.heading_letter_spacing | divided_by: 100.0 }}em;
        --button-font-size: {{ settings.button_font_size }}px;
        --button-font-weight: {{ settings.button_font_weight }};
        --button-letter-spacing: {{ settings.button_letter_spacing | divided_by: 100.0 }}em;
        --button-text-transform: {% if settings.button_uppercase %}uppercase{% else %}none{% endif %};
        --navigation-font-size: {{ settings.navigation_font_size }}px;
        --navigation-font-weight: {{ settings.navigation_font_weight }};
        --navigation-letter-spacing: {{ settings.navigation_letter_spacing | divided_by: 100.0 }}em;
        --navigation-text-transform: {% if settings.navigation_uppercase %}uppercase{% else %}none{% endif %};
        --page-width: {{ settings.page_width }}px;
        --content-width-narrow: {{ settings.content_width_narrow }}px;
        --content-width-standard: {{ settings.content_width_standard }}px;
        --content-width-wide: {{ settings.content_width_wide }}px;
        --page-padding-desktop: {{ settings.page_padding_desktop }}px;
        --page-padding-mobile: {{ settings.page_padding_mobile }}px;
        --section-spacing: {{ settings.section_spacing }}px;
        --grid-gap: {{ settings.grid_gap }}px;
        --product-grid-spacing: var(--grid-gap);
        --button-radius: {{ settings.button_radius }}px;
        --button-border-thickness: {{ settings.button_border_thickness }}px;
        --button-padding-horizontal: {{ settings.button_padding_horizontal }}px;
        --button-padding-vertical: {{ settings.button_padding_vertical }}px;
        --input-radius: {{ settings.input_radius }}px;
        --input-border-thickness: {{ settings.input_border_thickness }}px;
        --input-padding: {{ settings.input_padding }}px;
        --card-radius: {{ settings.card_radius }}px;
        --corner-radius: var(--card-radius);
        --image-radius: {{ settings.image_radius }}px;
        --card-border-width: {{ settings.card_border_width }}px;
        --card-border-color: {{ settings.card_border_color }};
        --card-background: {{ settings.card_background }};
        --card-shadow: {% case settings.card_shadow_style %}{% when 'none' %}none{% when 'medium' %}0 .75rem 2rem rgb(0 0 0 / .12){% when 'strong' %}0 1rem 3rem rgb(0 0 0 / .18){% else %}0 .25rem 1rem rgb(0 0 0 / .06){% endcase %};
        --animation-duration: {{ settings.animation_duration }}ms;
        --reveal-distance: {{ settings.reveal_distance }}px;
        --hover-transform: {% case settings.hover_animation_style %}{% when 'none' %}none{% when 'zoom' %}scale(1.02){% else %}translateY(-2px){% endcase %};
      }
    </style>
    {{ 'base.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </head>
  <body data-header-width="{{ settings.header_width_behavior }}" data-footer-width="{{ settings.footer_width_behavior }}" data-show-search="{{ settings.show_search }}" data-show-account="{{ settings.show_account }}" data-show-cart="{{ settings.show_cart }}" data-hover-style="{{ settings.hover_animation_style }}" data-reveal-animation="{{ settings.enable_reveal_animation }}" data-reveal-style="{{ settings.section_reveal_style }}" data-button-hover="{{ settings.enable_button_hover_effects }}" data-link-hover="{{ settings.enable_link_hover_effects }}" data-image-hover="{{ settings.enable_image_hover_effects }}" data-card-hover="{{ settings.enable_card_hover_effects }}">
    <a class="skip-link" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>
    {% sections 'header-group' %}
    <main id="MainContent" class="main-content" role="main" tabindex="-1">{{ content_for_layout }}</main>
    {% sections 'footer-group' %}
    {% section 'newsletter-popup' %}
    {% section 'privacy-banner' %}
    {% section 'age-verification' %}
  </body>
</html>
